<?xml version="1.0" encoding="utf-8"?>
<!-- Override the root config's exclusive Stride.* → stride-local mapping: samples
     map Stride.* to BOTH feeds so older versions fall back to nuget.org when bin/packages
     doesn't have that version. The dual mapping also handles 3rd-party Stride-prefix
     packages naturally (stride-local empty → nuget.org), so no carve-outs needed
     here — unlike the root config where the mapping is exclusive. -->
<configuration>
  <packageSourceMapping>
    <clear />
    <packageSource key="nuget.org">
      <package pattern="*" />
      <package pattern="Stride" />
      <package pattern="Stride.*" />
    </packageSource>
    <packageSource key="stride-local">
      <package pattern="Stride" />
      <package pattern="Stride.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
