<?xml version="1.0" encoding="utf-8"?>
<!-- Samples map Stride.* to nuget.org as well (the root config maps it to bin/packages only),
     so a committed sample restores in a fresh clone without building the engine first: its
     released Stride version comes from nuget.org, while a locally built version still resolves
     from bin/packages. The root config stays exclusive on purpose — engine restores should fail
     loudly rather than silently pull public packages when local packaging breaks. -->
<configuration>
  <packageSourceMapping>
    <clear />
    <packageSource key="nuget.org">
      <package pattern="*" />
      <package pattern="Stride" />
      <package pattern="Stride.*" />
    </packageSource>
    <packageSource key="stride-local">
      <package pattern="Stride" />
      <package pattern="Stride.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
