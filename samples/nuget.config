<?xml version="1.0" encoding="utf-8"?>
<!-- Override the root config's exclusive Stride.* → stride-local mapping: samples
     map Stride.* to ALL feeds so older versions fall back to nuget.org when bin/packages
     doesn't have that version, and dev-stub builds (StrideDevPackages) resolve from the
     "Stride Dev" feed (NugetDev), where auto-pack is disabled so bin/packages is stale.
     The multi mapping also handles 3rd-party Stride-prefix packages naturally (the Stride
     feeds are empty for them → nuget.org), so no carve-outs needed here — unlike the root
     config where the mapping is exclusive.

     "Stride Dev" is registered per-OS at the user level by NuGetAssemblyResolver; on a build
     without it (CI, which never uses dev stubs) the mapping entry is simply inert. -->
<configuration>
  <packageSourceMapping>
    <clear />
    <packageSource key="nuget.org">
      <package pattern="*" />
      <package pattern="Stride" />
      <package pattern="Stride.*" />
    </packageSource>
    <packageSource key="stride-local">
      <package pattern="Stride" />
      <package pattern="Stride.*" />
    </packageSource>
    <packageSource key="Stride Dev">
      <package pattern="Stride" />
      <package pattern="Stride.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
