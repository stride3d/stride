<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>
    <SupportedOSPlatformVersion>10.0</SupportedOSPlatformVersion>
    <OutputType>Exe</OutputType>
    <RootNamespace>MyTemplate.iOS</RootNamespace>
    <OutputPath>..\Bin\iOS\$(Configuration)\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <ApplicationId>MyTemplate</ApplicationId>
    <ApplicationVersion>1</ApplicationVersion>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <DisableFastUpToDateCheck>true</DisableFastUpToDateCheck>
    <StrideCurrentPackagePath>$(MSBuildThisFileDirectory)..\MyTemplate\MyTemplate.sdpkg</StrideCurrentPackagePath>
    <StrideProjectType>Executable</StrideProjectType>
    <StridePlatform>iOS</StridePlatform>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\MyTemplate\MyTemplate.csproj" />
  </ItemGroup>
</Project>
