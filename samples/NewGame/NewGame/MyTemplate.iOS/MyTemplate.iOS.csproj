<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0-ios</TargetFramework>
    <SupportedOSPlatformVersion>12.2</SupportedOSPlatformVersion>
    <OutputType>Exe</OutputType>
    <RootNamespace>MyTemplate.iOS</RootNamespace>
    <OutputPath>..\Bin\iOS\$(Configuration)\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <ApplicationId>MyTemplate</ApplicationId>
    <ApplicationVersion>1</ApplicationVersion>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <DisableFastUpToDateCheck>true</DisableFastUpToDateCheck>
    <StrideCurrentPackagePath>$(MSBuildThisFileDirectory)..\MyTemplate.Game\MyTemplate.Game.sdpkg</StrideCurrentPackagePath>
    <StridePlatform>iOS</StridePlatform>
  </PropertyGroup>
  <!-- Debug = Mono interpreter (fast iteration). Release = NativeAOT (ship quality). -->
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <UseInterpreter>true</UseInterpreter>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <PublishAot>true</PublishAot>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\MyTemplate.Game\MyTemplate.Game.csproj" />
  </ItemGroup>
</Project>
