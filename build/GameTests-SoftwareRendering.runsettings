<?xml version="1.0" encoding="utf-8"?>
<!--
  Run settings for software rendering tests (WARP / SwiftShader).
  Select this in Visual Studio via Test > Configure Run Settings > Select Solution Wide runsettings File.
-->
<RunSettings>
  <RunConfiguration>
    <EnvironmentVariables>
      <STRIDE_GRAPHICS_SOFTWARE_RENDERING>1</STRIDE_GRAPHICS_SOFTWARE_RENDERING>
      <STRIDE_MAX_PARALLELISM>8</STRIDE_MAX_PARALLELISM>
    </EnvironmentVariables>
  </RunConfiguration>
</RunSettings>
