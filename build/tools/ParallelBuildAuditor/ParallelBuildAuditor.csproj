<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Stride.Tools.ParallelBuildAuditor</RootNamespace>
    <AssemblyName>ParallelBuildAuditor</AssemblyName>
    <StrideRuntime>false</StrideRuntime>
    <StrideAssemblyProcessor>false</StrideAssemblyProcessor>
    <StrideCodeAnalysis>false</StrideCodeAnalysis>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="MSBuild.StructuredLogger" Version="2.2.243" />
    <PackageReference Include="Microsoft.Build" Version="17.14.9" />
    <PackageReference Include="Microsoft.Build.Framework" Version="17.14.9" />
  </ItemGroup>
</Project>
