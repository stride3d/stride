<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Auto-pack output. Stride.* dev versions shadow public ones during restore. -->
    <add key="stride-local" value="bin/packages" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
      <!-- Stride.* fallback for 3rd-party packages with Stride prefix (Stride.GNU.Gettext etc.). -->
      <package pattern="Stride.*" />
    </packageSource>
    <packageSource key="stride-local">
      <package pattern="Stride.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
