<!-- TreatAsLocalProperty="StrideSkipAutoPack": see Stride.Templates.Games.csproj. -->
<Project Sdk="Microsoft.Build.NoTargets" TreatAsLocalProperty="StrideSkipAutoPack">
  <PropertyGroup>
    <PackageId>Stride.Templates.Samples</PackageId>
    <StrideTemplateContentVersioned>true</StrideTemplateContentVersioned>
    <Title>Stride Samples</Title>
    <Description>dotnet new feature-demo samples for Stride (tutorials, games, graphics, UI, physics, particles, input, audio).</Description>
    <PackageTags>dotnet-new;templates;stride;stride-template;stride-sample;gamedev</PackageTags>
  </PropertyGroup>

  <Import Project="..\Stride.Templates.Common.targets" />

  <ItemGroup>
    <!-- Tutorials -->
    <StrideSampleTemplate Include="stride-csharp-beginner">
      <SamplePath>$(StrideRoot)samples/Tutorials/CSharpBeginner/CSharpBeginner</SamplePath>
    </StrideSampleTemplate>
    <StrideSampleTemplate Include="stride-csharp-intermediate">
      <SamplePath>$(StrideRoot)samples/Tutorials/CSharpIntermediate/CSharpIntermediate</SamplePath>
    </StrideSampleTemplate>
    <!-- Games (small playable samples) -->
    <StrideSampleTemplate Include="stride-jumpyjet">
      <SamplePath>$(StrideRoot)samples/Games/JumpyJet</SamplePath>
    </StrideSampleTemplate>
    <StrideSampleTemplate Include="stride-spaceescape">
      <SamplePath>$(StrideRoot)samples/Games/SpaceEscape</SamplePath>
    </StrideSampleTemplate>
    <!-- Feature demos -->
    <StrideSampleTemplate Include="stride-audio">
      <SamplePath>$(StrideRoot)samples/Audio/SimpleAudio</SamplePath>
    </StrideSampleTemplate>
    <StrideSampleTemplate Include="stride-particles">
      <SamplePath>$(StrideRoot)samples/Particles/ParticlesSample</SamplePath>
    </StrideSampleTemplate>
    <StrideSampleTemplate Include="stride-spritestudio">
      <SamplePath>$(StrideRoot)samples/Graphics/SpriteStudioDemo</SamplePath>
    </StrideSampleTemplate>
    <StrideSampleTemplate Include="stride-animatedmodel">
      <SamplePath>$(StrideRoot)samples/Graphics/AnimatedModel</SamplePath>
    </StrideSampleTemplate>
    <StrideSampleTemplate Include="stride-spritefonts">
      <SamplePath>$(StrideRoot)samples/Graphics/SpriteFonts</SamplePath>
    </StrideSampleTemplate>
    <StrideSampleTemplate Include="stride-materialshader">
      <SamplePath>$(StrideRoot)samples/Graphics/MaterialShader</SamplePath>
    </StrideSampleTemplate>
    <StrideSampleTemplate Include="stride-customeffect">
      <SamplePath>$(StrideRoot)samples/Graphics/CustomEffect</SamplePath>
    </StrideSampleTemplate>
    <StrideSampleTemplate Include="stride-bepuphysics">
      <SamplePath>$(StrideRoot)samples/Physics/BepuSample</SamplePath>
    </StrideSampleTemplate>
    <StrideSampleTemplate Include="stride-physics">
      <SamplePath>$(StrideRoot)samples/Physics/PhysicsSample</SamplePath>
    </StrideSampleTemplate>
    <StrideSampleTemplate Include="stride-touchinputs">
      <SamplePath>$(StrideRoot)samples/Input/TouchInputs</SamplePath>
    </StrideSampleTemplate>
    <StrideSampleTemplate Include="stride-gravitysensor">
      <SamplePath>$(StrideRoot)samples/Input/GravitySensor</SamplePath>
    </StrideSampleTemplate>
    <StrideSampleTemplate Include="stride-ui-menu">
      <SamplePath>$(StrideRoot)samples/UI/GameMenu</SamplePath>
    </StrideSampleTemplate>
    <StrideSampleTemplate Include="stride-ui-elementlink">
      <SamplePath>$(StrideRoot)samples/UI/UIElementLink</SamplePath>
    </StrideSampleTemplate>
    <StrideSampleTemplate Include="stride-ui-particles">
      <SamplePath>$(StrideRoot)samples/UI/UIParticles</SamplePath>
    </StrideSampleTemplate>
  </ItemGroup>

  <!-- Static literal-wildcard inputs so a sample edit triggers a repack (CPS needs pre-expanded paths; see
       Common.targets). One per StrideSampleTemplate above; bin/obj aren't excluded (source samples stay clean). -->
  <ItemGroup>
    <UpToDateCheckInput Include="$(StrideRoot)samples/Tutorials/CSharpBeginner/CSharpBeginner/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/Tutorials/CSharpIntermediate/CSharpIntermediate/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/Games/JumpyJet/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/Games/SpaceEscape/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/Audio/SimpleAudio/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/Particles/ParticlesSample/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/Graphics/SpriteStudioDemo/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/Graphics/AnimatedModel/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/Graphics/SpriteFonts/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/Graphics/MaterialShader/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/Graphics/CustomEffect/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/Physics/BepuSample/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/Physics/PhysicsSample/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/Input/TouchInputs/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/Input/GravitySensor/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/UI/GameMenu/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/UI/UIElementLink/**/*" />
    <UpToDateCheckInput Include="$(StrideRoot)samples/UI/UIParticles/**/*" />
  </ItemGroup>
</Project>
