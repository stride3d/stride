<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Imported via $(AfterMicrosoftNETSdkTargets) AFTER Xamarin.Shared.Sdk.Publish.targets so the
       _PrePublish redefinition wins. See Stride.Core.targets for the appender that wires this in. -->
  <Target Name="_PrePublish">
    <PropertyGroup>
      <BuildIpa Condition="'$(BuildIpa)' == '' And '$(SdkIsMobile)' == 'true'">true</BuildIpa>
      <CreatePackage Condition="'$(CreatePackage)' == '' And '$(SdkIsDesktop)' == 'true'">true</CreatePackage>
      <IpaPackageDir Condition="'$(IpaPackageDir)' == '' And '$(IpaPackagePath)' == ''">$(PublishDir)</IpaPackageDir>
      <PkgPackageDir Condition="'$(PkgPackageDir)' == '' And '$(PkgPackagePath)' == ''">$(PublishDir)</PkgPackageDir>
    </PropertyGroup>
  </Target>

</Project>
