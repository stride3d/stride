<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- ==================================================================
       Stride graphics API consumer-side targets.

       Two concerns handled here:
       1. _StridePackageReferenceResolveGraphicsApi  - for multi-DLL Stride
          packages (Stride.Graphics, Stride.Games, etc.), pick the sub-folder
          matching the current StrideGraphicsApi instead of the top-level
          (placeholder) copy.
       2. _StrideFilterGraphicsApiSpecificPackages            - strip copy-local runtime
          assets from native/interop packages (Silk.NET.Direct3D12, etc.) that
          Stride pulls transitively for APIs the consumer isn't using.  Only
          strips when every requester of the package is a Stride contributor
          (listed in @(StrideGraphicsApiFilterContributor)) and the user hasn't asked
          for the package directly.
  -->

  <!-- API-specific packages Stride pulls per graphics API.  A package can
       belong to several APIs (e.g. DXGI is shared between D3D11 and D3D12).
       The filter strips a package when the current API is NOT in its
       GraphicsApis metadata AND no non-Stride source requested it. -->
  <ItemGroup>
    <!-- Silk.NET.Direct3D11 is intentionally kept on every build: the FXC-based
         shader compiler (Stride.Shaders.Compiler.Direct3D.ShaderCompiler) uses
         ID3D11ShaderReflection from d3dcompiler.dll for DXBC reflection on both
         D3D11 and D3D12 targets. -->
    <StrideGraphicsApiSpecificPackage Include="Silk.NET.Direct3D12"         GraphicsApis="Direct3D12" />
    <StrideGraphicsApiSpecificPackage Include="Silk.NET.DXGI"               GraphicsApis="Direct3D11;Direct3D12" />
    <!-- DXC is needed to natively compile HLSL on D3D.  Stride.Assets owns
         the cross-compile rule: it ships its own buildTransitive targets that
         add Vulkan to this list so DXC survives when the asset pipeline is in
         the consumer graph.  A pure runtime Vulkan project that also compiles
         HLSL at runtime can opt back in with a direct <PackageReference>. -->
    <StrideGraphicsApiSpecificPackage Include="Silk.NET.Direct3D.Compilers" GraphicsApis="Direct3D11;Direct3D12" />
    <StrideGraphicsApiSpecificPackage Include="WinPixEventRuntime"          GraphicsApis="Direct3D12" />
    <StrideGraphicsApiSpecificPackage Include="Vortice.Vulkan"              GraphicsApis="Vulkan" />
  </ItemGroup>

  <!-- Stride libraries that pull API-specific packages.  A package is treated
       as "Stride-origin" when ALL of its requesters (either the current
       project if it is itself a contributor, or transitive parents in the
       restored graph) are in this list.  Third-party plugins that want to
       opt into the same stripping semantics can append to this item group
       from their own buildTransitive targets. -->
  <ItemGroup>
    <StrideGraphicsApiFilterContributor Include="Stride.Graphics" />
    <StrideGraphicsApiFilterContributor Include="Stride.Games" />
    <StrideGraphicsApiFilterContributor Include="Stride.Input" />
    <StrideGraphicsApiFilterContributor Include="Stride.Video" />
    <StrideGraphicsApiFilterContributor Include="Stride.VirtualReality" />
  </ItemGroup>

  <!-- ==================================================================
       Target for PackageReference to properly select .dll from appropriate StrideGraphicsApi
  -->
  <Target Name="_StridePackageReferenceResolveGraphicsApi" AfterTargets="ResolvePackageAssets">
    <PropertyGroup>
      <!-- Transmit current graphics API. This is useful in case we have transitions such as: Direct3D12->ProjectWithoutGraphicsApi->Direct3D12
           otherwise it would try to build 3rd project twice (due to the reference from ProjectWithoutGraphicsApi). -->
      <_StrideGraphicsApiCurrent>$(StrideGraphicsApi)</_StrideGraphicsApiCurrent>
      <!-- We use a fallback in case the project without graphics API is the project initiating the build. -->
      <_StrideGraphicsApiCurrent Condition="'$(_StrideGraphicsApiCurrent)' == '' And '$(StrideGraphicsApis)' != ''">$(StrideGraphicsApis.Split(';', StringSplitOptions.RemoveEmptyEntries)[0])</_StrideGraphicsApiCurrent>
      <_StrideGraphicsApiCurrent Condition="'$(_StrideGraphicsApiCurrent)' == ''">$(StrideDefaultGraphicsApi)</_StrideGraphicsApiCurrent>
      <_StrideGraphicsApiCurrent Condition="'$(_StrideGraphicsApiCurrent)' == ''">Direct3D11</_StrideGraphicsApiCurrent>
    </PropertyGroup>
    <ItemGroup>
      <_StrideGraphicsRuntimeCopyLocalFolders Include="@(RuntimeCopyLocalItems->'%(RootDir)%(Directory)$(_StrideGraphicsApiCurrent)')" Condition="'%(NuGetPackageId)' != '' And Exists('%(RootDir)%(Directory)$(_StrideGraphicsApiCurrent)')">
      </_StrideGraphicsRuntimeCopyLocalFolders>
      <RuntimeCopyLocalItems Remove="@(RuntimeCopyLocalItems)" Condition="'%(NuGetPackageId)' != '' And Exists('%(RootDir)%(Directory)$(_StrideGraphicsApiCurrent)\')">
      </RuntimeCopyLocalItems>
    </ItemGroup>

    <!-- There might have been multiple RuntimeCopyLocalItems in the same folder, resulting in multiple identical _StrideGraphicsRuntimeCopyLocalFolders -->
    <RemoveDuplicates Inputs="@(_StrideGraphicsRuntimeCopyLocalFolders)">
      <Output TaskParameter="Filtered" ItemName="_StrideGraphicsRuntimeCopyLocalFoldersFiltered" />
    </RemoveDuplicates>

    <!-- Expand .dll/.exe specific to this Graphics API -->
    <CreateItem Include="@(_StrideGraphicsRuntimeCopyLocalFoldersFiltered->'%(Identity)\*.dll')" AdditionalMetadata="CopyLocal=true;AssetType=runtime" PreserveExistingMetadata="false">
      <Output TaskParameter="Include" ItemName="_StrideGraphicsRuntimeCopyLocal" />
    </CreateItem>
    <CreateItem Include="@(_StrideGraphicsRuntimeCopyLocalFoldersFiltered->'%(Identity)\*.exe')" AdditionalMetadata="CopyLocal=true;AssetType=runtime" PreserveExistingMetadata="false">
      <Output TaskParameter="Include" ItemName="_StrideGraphicsRuntimeCopyLocal" />
    </CreateItem>

    <ItemGroup>
      <_StrideGraphicsRuntimeCopyLocal Update="@(_StrideGraphicsRuntimeCopyLocal)">
        <DestinationSubPath>%(Filename)%(Extension)</DestinationSubPath>
        <PathInPackage>$([System.Text.RegularExpressions.Regex]::Match('%(PathInPackage)', `(.*)/[^/]*`).get_Groups().get_Item(1).ToString())/$(_StrideGraphicsApiCurrent)/%(Filename)%(Extension)</PathInPackage>
      </_StrideGraphicsRuntimeCopyLocal>

      <RuntimeCopyLocalItems Include="@(_StrideGraphicsRuntimeCopyLocal)" />
    </ItemGroup>
  </Target>

  <!-- ==================================================================
       Strip copy-local items for API-specific packages Stride pulls for
       graphics APIs the consumer is not using.

       Runs after _StridePackageReferenceResolveGraphicsApi so we don't fight
       with its multi-DLL sub-folder mutation.  Preserves a package when any
       non-Stride source has requested it: either the current project's own
       <PackageReference> (when the project is not itself a Stride contributor)
       or a transitive parent not listed in @(StrideGraphicsApiFilterContributor).

       Only affects the bin/ copy of runtime assets.  Restore still downloads
       the packages (their .nuspec deps are unchanged); we just don't ship
       the DLLs to the consumer's output directory.
  -->
  <Target Name="_StrideFilterGraphicsApiSpecificPackages"
          AfterTargets="ResolvePackageAssets"
          DependsOnTargets="_StridePackageReferenceResolveGraphicsApi">
    <PropertyGroup>
      <!-- Reuse the API resolution from _StridePackageReferenceResolveGraphicsApi. -->
      <_StrideGraphicsApiCurrent>$(StrideGraphicsApi)</_StrideGraphicsApiCurrent>
      <_StrideGraphicsApiCurrent Condition="'$(_StrideGraphicsApiCurrent)' == '' And '$(StrideGraphicsApis)' != ''">$(StrideGraphicsApis.Split(';', StringSplitOptions.RemoveEmptyEntries)[0])</_StrideGraphicsApiCurrent>
      <_StrideGraphicsApiCurrent Condition="'$(_StrideGraphicsApiCurrent)' == ''">$(StrideDefaultGraphicsApi)</_StrideGraphicsApiCurrent>
      <_StrideGraphicsApiCurrent Condition="'$(_StrideGraphicsApiCurrent)' == ''">Direct3D11</_StrideGraphicsApiCurrent>

      <!-- Semicolon-wrapped forms so we can use .Contains(';id;') checks below. -->
      <_StrideContributorIds>;@(StrideGraphicsApiFilterContributor);</_StrideContributorIds>
      <_StrideIsContributorSelf Condition="$(_StrideContributorIds.Contains(';$(MSBuildProjectName);'))">true</_StrideIsContributorSelf>
    </PropertyGroup>

    <!-- Candidate packages: API-specific packages whose GraphicsApis metadata
         does NOT include the current API.  Everything else is left alone. -->
    <ItemGroup>
      <_StrideGraphicsApiStripCandidate Include="@(StrideGraphicsApiSpecificPackage)"
        Condition="!$([System.String]::Copy(';%(StrideGraphicsApiSpecificPackage.GraphicsApis);').Contains(';$(_StrideGraphicsApiCurrent);'))" />
    </ItemGroup>
    <PropertyGroup>
      <_StrideGraphicsApiStripIds>;@(_StrideGraphicsApiStripCandidate);</_StrideGraphicsApiStripIds>
    </PropertyGroup>

    <!-- Aggregate of all non-Stride-origin requests for any package id.  A
         package is considered requested by:
         - The current project's direct PackageReferences, when the current
           project is NOT itself a Stride contributor (end-user game project).
         - Any transitive parent whose name is not in @(StrideGraphicsApiFilterContributor). -->
    <ItemGroup>
      <_StrideNonStrideRequester Include="@(PackageReference)"
        Condition="'$(_StrideIsContributorSelf)' != 'true'" />
      <_StrideNonStrideRequester Include="@(PackageDependencies->'%(Identity)')"
        Condition="'%(PackageDependencies.ParentPackage)' != '' And !$(_StrideContributorIds.Contains(';%(PackageDependencies.ParentPackage);'))" />
    </ItemGroup>
    <PropertyGroup>
      <_StrideNonStrideRequesterIds>;@(_StrideNonStrideRequester);</_StrideNonStrideRequesterIds>
    </PropertyGroup>

    <!-- Final filter: drop copy-local runtime items from stripped packages that
         no non-Stride source has requested.  Also clear the parallel
         ReferenceCopyLocalPaths items so nothing falls through to output. -->
    <ItemGroup>
      <RuntimeCopyLocalItems Remove="@(RuntimeCopyLocalItems)"
        Condition="'%(NuGetPackageId)' != '' And
                   $(_StrideGraphicsApiStripIds.Contains(';%(NuGetPackageId);')) And
                   !$(_StrideNonStrideRequesterIds.Contains(';%(NuGetPackageId);'))" />
      <ReferenceCopyLocalPaths Remove="@(ReferenceCopyLocalPaths)"
        Condition="'%(NuGetPackageId)' != '' And
                   $(_StrideGraphicsApiStripIds.Contains(';%(NuGetPackageId);')) And
                   !$(_StrideNonStrideRequesterIds.Contains(';%(NuGetPackageId);'))" />
    </ItemGroup>
  </Target>

</Project>
