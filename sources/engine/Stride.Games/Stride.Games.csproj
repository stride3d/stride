<Project>
  <Import Project="$([MSBuild]::GetDirectoryNameOfFileAbove($(MSBuildProjectDirectory), 'Directory.Build.props'))/sdk/Stride.Build.Sdk/Sdk/Sdk.props" />
  <PropertyGroup>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <StrideRuntime>true</StrideRuntime>
    <StrideExplicitWindowsRuntime>true</StrideExplicitWindowsRuntime>
    <StrideGraphicsApiDependent>true</StrideGraphicsApiDependent>
    <StrideAssemblyProcessor>true</StrideAssemblyProcessor>
    <StrideAssemblyProcessorOptions>--auto-module-initializer</StrideAssemblyProcessorOptions>
    <StrideCodeAnalysis>true</StrideCodeAnalysis>
    <UseWPF Condition="$(TargetFramework.Contains('-windows'))">true</UseWPF>
    <UseWindowsForms Condition="$(TargetFramework.Contains('-windows'))">true</UseWindowsForms>
  </PropertyGroup>
  <Choose>
    <When Condition=" '$(TargetFramework)' == '$(StrideFrameworkAndroid)'">
      <ItemGroup>
        <AndroidResource Include="Platforms\Android\Resources\Layout\stride_popup_edittext.xml" />
      </ItemGroup>
    </When>
  </Choose>
  <ItemGroup>
    <Compile Include="..\..\shared\SharedAssemblyInfo.cs">
      <Link>Properties\SharedAssemblyInfo.cs</Link>
    </Compile>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Stride.Graphics\Stride.Graphics.csproj" />
    <PackageReference Include="Silk.NET.Sdl" PrivateAssets="compile" />
    <PackageReference Include="Silk.NET.Windowing.Sdl" Condition="'$(TargetFramework)' == '$(StrideFrameworkAndroid)'" />
    <PackageReference Include="Silk.NET.Windowing.Sdl" Condition="'$(TargetFramework)' == '$(StrideFrameworkiOS)'" PrivateAssets="compile" />
  </ItemGroup>
  <Import Project="$(StrideRoot)sources/sdk/Stride.Build.Sdk/Sdk/Sdk.targets" />
</Project>
