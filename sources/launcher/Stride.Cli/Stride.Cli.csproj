<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Stride.Cli</RootNamespace>
    <AssemblyName>stride</AssemblyName>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>stride</ToolCommandName>
    <PackageId>Stride.Cli</PackageId>
    <VersionPrefix>1.0.0</VersionPrefix>
    <Description>Command-line tool for Stride: install Stride versions and create, build, and manage Stride projects.</Description>
    <PackageTags>stride;gamedev;cli;dotnet-tool</PackageTags>
  </PropertyGroup>
  <!-- License, project/repository URL, icon, copyright and authors shared with the engine packages. -->
  <Import Project="..\..\sdk\Stride.Build.Sdk\Stride.PackageMetadata.props" />
  <ItemGroup>
    <PackageReference Include="System.CommandLine" />
    <PackageReference Include="Microsoft.TemplateEngine.Abstractions" />
    <PackageReference Include="Microsoft.TemplateEngine.Edge" />
    <PackageReference Include="Microsoft.TemplateEngine.IDE" />
    <!-- legacy generate-legacy-shader-code: talks to the released Stride.VisualStudio.Commands over ServiceWire.
         System.Formats.Nrbf reads the BinaryFormatter handshake payload from pre-4.2 (ServiceWire 5.3.4) servers. -->
    <PackageReference Include="ServiceWire" />
    <PackageReference Include="System.Formats.Nrbf" />
  </ItemGroup>
  <!-- Linked from the shared/old-package sources so we can restore+locate and talk to the released Commands. -->
  <ItemGroup>
    <Compile Include="..\..\shared\Stride.NuGetResolver\GraphicsApiSelector.cs" Link="Legacy\Shared\GraphicsApiSelector.cs" />
    <Compile Include="..\..\shared\Stride.NuGetResolver\RestoreHelper.cs" Link="Legacy\Shared\RestoreHelper.cs" />
    <Compile Include="..\..\shared\LoaderToolLocator\LoaderToolLocator.cs" Link="Legacy\Shared\LoaderToolLocator.cs" />
  </ItemGroup>
  <!-- IStrideCommands ABI lives in an assembly named Stride.VisualStudio.Commands.Interfaces so ServiceWire's
       assembly-qualified type keys match the released server. See that project for details. -->
  <ItemGroup>
    <ProjectReference Include="..\Stride.VisualStudio.Commands.Interfaces.Client\Stride.VisualStudio.Commands.Interfaces.Client.csproj" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\assets\Stride.Core.Packages\Stride.Core.Packages.csproj" />
    <ProjectReference Include="..\..\core\Stride.Core.Design\Stride.Core.Design.csproj" />
  </ItemGroup>
  <!-- Engine-dependency-free template-engine glue, shared by source with Stride.Assets rather than
       referencing the engine assembly. -->
  <ItemGroup>
    <Compile Include="..\..\engine\Stride.Assets\Templates\DotNetNewTemplateRegistry.cs" Link="Core\Templates\DotNetNewTemplateRegistry.cs" />
    <Compile Include="..\..\engine\Stride.Assets\Templates\StrideTemplateEngineEnvironment.cs" Link="Core\Templates\StrideTemplateEngineEnvironment.cs" />
  </ItemGroup>
</Project>
