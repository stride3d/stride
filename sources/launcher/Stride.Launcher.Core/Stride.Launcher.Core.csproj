<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Stride.Launcher.Core</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.TemplateEngine.Abstractions" />
    <PackageReference Include="Microsoft.TemplateEngine.Edge" />
    <PackageReference Include="Microsoft.TemplateEngine.IDE" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\assets\Stride.Core.Packages\Stride.Core.Packages.csproj" />
    <ProjectReference Include="..\..\core\Stride.Core.Design\Stride.Core.Design.csproj" />
  </ItemGroup>
  <!-- Engine-dependency-free template-engine glue, shared by source with Stride.Assets rather than
       referencing the engine assembly. -->
  <ItemGroup>
    <Compile Include="..\..\engine\Stride.Assets\Templates\DotNetNewTemplateRegistry.cs" Link="Templates\DotNetNewTemplateRegistry.cs" />
    <Compile Include="..\..\engine\Stride.Assets\Templates\StrideTemplateEngineEnvironment.cs" Link="Templates\StrideTemplateEngineEnvironment.cs" />
  </ItemGroup>
</Project>
