<Project Sdk="Microsoft.NET.Sdk">
  <!-- Trusted runner for the screenshot vision gate. Built from a base/master checkout so it executes
       trusted comparator code on a (fork) PR's image artifacts (data), never PR-built code. Plain
       Microsoft.NET.Sdk on purpose — no Stride build machinery needed; it just references the comparator
       library, whose ONNX model + ImageSharp/OnnxRuntime deps flow in via ProjectReference. -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Stride.ScreenshotComparator\Stride.ScreenshotComparator.csproj" />
  </ItemGroup>
</Project>
