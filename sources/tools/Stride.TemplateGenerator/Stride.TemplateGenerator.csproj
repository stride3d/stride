<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Stride.TemplateGenerator</RootNamespace>
    <Nullable>enable</Nullable>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Mono.Options" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\..\shared\SharedAssemblyInfo.cs">
      <Link>Properties\SharedAssemblyInfo.cs</Link>
    </Compile>
    <Compile Include="..\..\engine\Stride.Assets\Templates\SdtplMetadata.cs">
      <Link>SdtplMetadata.cs</Link>
    </Compile>
  </ItemGroup>
  <ItemGroup>
    <!-- Stride.Core for ILogger / GlobalLogger; no need for engine asset deps (preprocessor
         runs pure text transforms). -->
    <ProjectReference Include="..\..\core\Stride.Core\Stride.Core.csproj" />
    <ProjectReference Include="..\..\core\Stride.Core.Yaml\Stride.Core.Yaml.csproj" />
  </ItemGroup>
</Project>
