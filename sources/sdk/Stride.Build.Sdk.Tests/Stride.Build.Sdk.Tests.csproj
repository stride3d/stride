<Project Sdk="Microsoft.NET.Sdk">  
  <PropertyGroup>
    <!-- Package Identity -->
    <PackageId>Stride.Build.Sdk.Tests</PackageId>
    <PackageTags>$(PackageTags);tests;testing</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <!-- Exclude launcher .cs files from this project's compilation (they're for consuming projects) -->
    <Compile Remove="Sdk/**/*.cs" />

    <!-- Include SDK files in Sdk/ folder (required for MSBuild SDK resolution) -->
    <None Include="$(MSBuildThisFileDirectory)Sdk/**/*.props" Pack="true" PackagePath="Sdk/" />
    <None Include="$(MSBuildThisFileDirectory)Sdk/**/*.targets" Pack="true" PackagePath="Sdk/" />
    <None Include="$(MSBuildThisFileDirectory)Sdk/**/*.cs" Pack="true" PackagePath="Sdk/" />

  </ItemGroup>
</Project>