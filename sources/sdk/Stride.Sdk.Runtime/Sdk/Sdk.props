<!--
  Stride.Sdk.Runtime - SDK for multi-platform Stride runtime projects
  
  This SDK extends Stride.Sdk to enable multi-platform targeting.
  Use this SDK for projects that need to build for multiple platforms
  (Windows, Linux, macOS, Android, iOS, UWP).
  
  Usage: <Project Sdk="Stride.Sdk.Runtime">
-->
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Set StrideRuntime before importing base Stride.Sdk -->
  <PropertyGroup>
    <StrideRuntime>true</StrideRuntime>
  </PropertyGroup>

  <!-- Import the base Stride.Sdk which will now see StrideRuntime=true -->
  <Import Project="Sdk.props" Sdk="Stride.Sdk" />

</Project>