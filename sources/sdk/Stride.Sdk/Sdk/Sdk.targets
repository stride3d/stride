<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!--
    ================================================================
    Stride.Sdk - Build Logic and Targets (Sdk.targets)
    ================================================================

    EVALUATION ORDER: This file is imported AFTER the project file!

    What you CAN do here:
    - Check user-defined properties from .csproj (now visible!)
    - Compute derived properties based on user values
    - Conditionally enable features based on user properties
    - Define build targets and tasks

    What you should do here:
    - All conditional logic that depends on .csproj properties
    - Property computation based on user choices
    - Target framework expansion (StrideRuntime → TargetFrameworks)
    - Build customization based on user configuration

    Rule: User properties from .csproj ARE visible here.
          This is where conditional logic belongs.

    See: build/docs/SDK-WORK-GUIDE.md#understanding-property-evaluation-timing
         build/docs/SDK-PROPERTY-EVALUATION-ANALYSIS.md
    ================================================================
  -->

  <!-- ================================================================ -->
  <!-- Import supporting targets files -->
  <!-- ================================================================ -->
  <Import Project="Stride.Frameworks.targets" />
  <Import Project="Stride.Platform.targets" />
  <Import Project="Stride.Graphics.targets" />
  <Import Project="Stride.AssemblyProcessor.targets" />
  <Import Project="Stride.CodeAnalysis.targets" />
  <Import Project="Stride.PackageInfo.targets" />

  <!-- ================================================================ -->
  <!-- Import base Microsoft.NET.Sdk targets -->
  <!-- ================================================================ -->
  <!-- This gives us all standard .NET SDK functionality -->
  <Import Project="Sdk.targets" Sdk="Microsoft.NET.Sdk" />

  <!-- ================================================================ -->
  <!-- Native build mode configuration (Clang/MSVC selection) -->
  <!-- ================================================================ -->
  <Import Project="Stride.NativeBuildMode.props" />

  <!-- ================================================================ -->
  <!-- Shader Code Generation Support -->
  <!-- ================================================================ -->
  <!-- Configure .sdsl and .sdfx files with their code generators,
       and mark generated .cs files as dependent on their source shader -->
  <ItemGroup>
    <Compile Update="**\*.sdsl.cs" DependentUpon="%(Filename)" />
    <None Update="**\*.sdsl" Generator="StrideShaderKeyGenerator" />
    <Compile Update="**\*.sdfx.cs" DependentUpon="%(Filename)" />
    <None Update="**\*.sdfx" Generator="StrideEffectCodeGenerator" />
  </ItemGroup>

  <!-- ================================================================ -->
  <!-- Stride.Core.CompilerServices Roslyn Analyzer -->
  <!-- ================================================================ -->
  <!-- Migrated from: sources/targets/Stride.Core-extended.props:295-300 -->
  <ItemGroup Condition="!$(MSBuildProjectName.StartsWith('Stride.Core.CompilerServices'))">
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\..\..\core\Stride.Core.CompilerServices\Stride.Core.CompilerServices.csproj"
                      OutputItemType="Analyzer"
                      SetTargetFramework="TargetFramework=netstandard2.0"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!-- ================================================================ -->
  <!-- StridePublicApi - User Documentation (.usrdoc) Support -->
  <!-- ================================================================ -->
  <!-- Migrated from: sources/targets/Stride.Core.targets:51-65 -->
  <PropertyGroup Condition="'$(StridePublicApi)' == 'true'">
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AllowedOutputExtensionsInPackageBuildOutputFolder>$(AllowedOutputExtensionsInPackageBuildOutputFolder);.usrdoc</AllowedOutputExtensionsInPackageBuildOutputFolder>
    <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);_StrideRegisterUserDocOutputs</TargetsForTfmSpecificBuildOutput>
  </PropertyGroup>
  <Target Name="_StrideRegisterUserDocOutputs">
    <ItemGroup Condition="Exists('$(OutputPath)$(AssemblyName).usrdoc')">
      <BuildOutputInPackage Include="$(OutputPath)$(AssemblyName).usrdoc"/>
    </ItemGroup>
  </Target>
  <Target Name="_StrideRegisterUserDocReferenceRelatedFileExtensions" Condition="'$(StridePublicApi)' == 'true'" BeforeTargets="ResolveAssemblyReferences">
    <PropertyGroup>
      <AllowedReferenceRelatedFileExtensions>$(AllowedReferenceRelatedFileExtensions);.usrdoc</AllowedReferenceRelatedFileExtensions>
    </PropertyGroup>
  </Target>

  <!-- ================================================================ -->
  <!-- StrideScript - Auto-enable Assembly Processor for scripts -->
  <!-- ================================================================ -->
  <!-- Migrated from: sources/targets/Stride.targets:6 -->
  <PropertyGroup>
    <StrideAssemblyProcessor Condition="'$(StrideScript)' == 'true'">true</StrideAssemblyProcessor>
  </PropertyGroup>

  <!-- ================================================================ -->
  <!-- SourceLink - GitHub Source Debugging -->
  <!-- ================================================================ -->
  <!-- Migrated from: sources/targets/Stride.Core-extended.props:276-279 -->
  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" Condition="'$(StrideProjectType)' == 'CSharp'" PrivateAssets="All" />
  </ItemGroup>

  <!-- ================================================================ -->
  <!-- Configuration Validation -->
  <!-- ================================================================ -->
  <Target Name="_StrideValidateConfiguration" BeforeTargets="Build">
    <Error Condition="'$(StrideGraphicsApiDependent)' == 'true' And '$(StrideGraphicsApi)' == ''"
           Text="StrideGraphicsApi must be set when StrideGraphicsApiDependent is true. Set a default in your project or use Stride.Graphics.props." />
    <Error Condition="'$(StrideAssemblyProcessor)' == 'true' And '$(StrideAssemblyProcessorPath)' != '' And !Exists('$(StrideAssemblyProcessorPath)')"
           Text="StrideAssemblyProcessorPath '$(StrideAssemblyProcessorPath)' does not exist. Rebuild the assembly processor or check the path." />
    <Warning Condition="'$(StridePlatform)' == ''"
             Text="StridePlatform is not set. Platform-specific features may not work correctly. Check Stride.Platform.props." />
  </Target>

</Project>