<Project Sdk="Microsoft.NET.Sdk">  
  <PropertyGroup>
    <!-- Package Identity -->
    <PackageId>Stride.Sdk</PackageId>
    <PackageTags>$(PackageTags)</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <!-- Include SDK files in Sdk/ folder (required for MSBuild SDK resolution) -->
    <None Include="$(MSBuildThisFileDirectory)Sdk/**/*.props" Pack="true" PackagePath="Sdk/" />
    <None Include="$(MSBuildThisFileDirectory)Sdk/**/*.targets" Pack="true" PackagePath="Sdk/" />

    <!-- Include build/ files for legacy NuGet PackageReference support -->
    <None Include="$(MSBuildThisFileDirectory)build/**/*.props" Pack="true" PackagePath="build/" />
    <None Include="$(MSBuildThisFileDirectory)build/**/*.targets" Pack="true" PackagePath="build/" />
  </ItemGroup>
</Project>