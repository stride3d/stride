<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!--
    ================================================================
    Stride.Sdk - Platform Detection and Configuration (Sdk.Platform.props)
    ================================================================

    EVALUATION PHASE: Early (BEFORE project file)

    This file sets platform-specific defaults that can be overridden by projects.

    ================================================================
  -->

  <!-- Framework constants are defined in Stride.Frameworks.props -->

  <!-- ================================================================ -->
  <!-- Platform Auto-Detection -->
  <!-- ================================================================ -->
  <PropertyGroup>
    <!-- Preserve original platform if already set -->
    <StridePlatformOriginal>$(StridePlatform)</StridePlatformOriginal>

    <!-- Detect platform from RuntimeIdentifier first, then TargetFramework, then OS -->
    <StridePlatform></StridePlatform>
    <StridePlatform Condition=" '$(RuntimeIdentifier.StartsWith(win))' ">Windows</StridePlatform>
    <StridePlatform Condition=" '$(RuntimeIdentifier.StartsWith(osx))' ">macOS</StridePlatform>
    <StridePlatform Condition=" '$(RuntimeIdentifier.StartsWith(linux))' ">Linux</StridePlatform>
    <StridePlatform Condition=" '$(StrideTargetFramework)' == '$(StrideFrameworkWindows)' ">Windows</StridePlatform>
    <StridePlatform Condition=" '$(StrideTargetFramework)' == '$(StrideFrameworkmacOS)' ">macOS</StridePlatform>
    <StridePlatform Condition=" '$(StrideTargetFramework)' == '$(StrideFrameworkUWP)' ">UWP</StridePlatform>
    <StridePlatform Condition=" '$(StrideTargetFramework)' == '$(StrideFrameworkAndroid)' ">Android</StridePlatform>
    <StridePlatform Condition=" '$(StrideTargetFramework)' == '$(StrideFrameworkiOS)' ">iOS</StridePlatform>
    <StridePlatform Condition=" '$(StridePlatform)' == '' And '$([MSBuild]::IsOSPlatform(Linux))' ">Linux</StridePlatform>
    <StridePlatform Condition=" '$(StridePlatform)' == '' And '$([MSBuild]::IsOSPlatform(OSX))' ">macOS</StridePlatform>
    <StridePlatform Condition=" '$(StridePlatform)' == '' ">Windows</StridePlatform>

    <!-- Platform full name (may be extended with build dir suffix) -->
    <StridePlatformFullName Condition="'$(StridePlatformFullName)' == ''">$(StridePlatform)</StridePlatformFullName>
    <StridePlatformFullName Condition="'$(StrideBuildDirExtension)' != ''">$(StridePlatformFullName)-$(StrideBuildDirExtension)</StridePlatformFullName>

    <!-- Platform dependencies -->
    <StridePlatformDeps Condition=" '$(StrideTargetFramework)' == '$(StrideFramework)' Or '$(StrideTargetFramework)' == '$(StrideFrameworkWindows)' Or '$(StrideTargetFramework)' == '$(StrideFrameworkmacOS)' ">dotnet</StridePlatformDeps>
    <StridePlatformDeps Condition=" '$(StrideTargetFramework)' == '$(StrideFrameworkUWP)' ">UWP</StridePlatformDeps>
    <StridePlatformDeps Condition=" '$(StrideTargetFramework)' == '$(StrideFrameworkAndroid)' ">Android</StridePlatformDeps>
    <StridePlatformDeps Condition=" '$(StrideTargetFramework)' == '$(StrideFrameworkiOS)' ">iOS</StridePlatformDeps>
  </PropertyGroup>

  <!-- ================================================================ -->
  <!-- Local Developer Settings (in-source only) -->
  <!-- ================================================================ -->
  <!-- Anchored on crowdin.yml at the repo root; absent for end-users consuming the SDK
       from NuGet, so the import no-ops there. The file is gitignored at build/Stride.Local.props
       and gets auto-created from Stride.Local.props.template by the _StrideBootstrapLocalProps
       target in Sdk.targets — so the first build runs with SDK defaults and the local file
       is picked up from the second build onward. Imports here so its values can override
       the $(StridePlatform)-keyed StrideGraphicsApis defaults below. -->
  <PropertyGroup>
    <_StrideRepoRoot>$([MSBuild]::GetDirectoryNameOfFileAbove('$(MSBuildThisFileDirectory)', 'crowdin.yml'))</_StrideRepoRoot>
    <_StrideLocalProps Condition="'$(_StrideRepoRoot)' != ''">$(_StrideRepoRoot)\build\Stride.Local.props</_StrideLocalProps>
    <_StrideLocalPropsTemplate>$(MSBuildThisFileDirectory)Stride.Local.props.template</_StrideLocalPropsTemplate>
  </PropertyGroup>

  <Import Project="$(_StrideLocalProps)" Condition="'$(_StrideLocalProps)' != '' And Exists('$(_StrideLocalProps)')" />

  <!-- ================================================================ -->
  <!-- StridePlatforms Default Detection -->
  <!-- ================================================================ -->
  <PropertyGroup>
    <StrideCommonPreSettingsName Condition="'$(StrideCommonPreSettingsName)' == ''">Stride</StrideCommonPreSettingsName>

    <!-- Set default StridePlatforms based on OS (if not already set by user/build system) -->
    <!-- Note: This MUST be set to enable multi-targeting with StrideRuntime=true -->
    <StridePlatforms Condition="'$(StridePlatforms)' == '' And '$([MSBuild]::IsOSPlatform(Windows))'">Windows</StridePlatforms>
    <StridePlatforms Condition="'$(StridePlatforms)' == '' And '$([MSBuild]::IsOSPlatform(OSX))'">macOS</StridePlatforms>
    <StridePlatforms Condition="'$(StridePlatforms)' == '' And '$([MSBuild]::IsOSPlatform(Linux))'">Linux</StridePlatforms>

    <!-- Unescape in case it was passed from Stride.build with escaped characters -->
    <StridePlatforms>$([MSBuild]::Unescape('$(StridePlatforms)'))</StridePlatforms>

    <!-- Create delimited version for .Contains() checks in Stride.Frameworks.targets -->
    <_StridePlatforms>;$(StridePlatforms);</_StridePlatforms>
  </PropertyGroup>

  <!-- ================================================================ -->
  <!-- Graphics API Defaults per Platform -->
  <!-- ================================================================ -->
  <PropertyGroup Condition="'$(StridePlatform)' == 'Windows'">
    <StrideGraphicsApis Condition="'$(StrideGraphicsApis)' == ''">Direct3D11</StrideGraphicsApis>
  </PropertyGroup>
  <PropertyGroup Condition="'$(StridePlatform)' == 'Linux'">
    <StrideGraphicsApis Condition="'$(StrideGraphicsApis)' == ''">Vulkan</StrideGraphicsApis>
  </PropertyGroup>
  <PropertyGroup Condition="'$(StridePlatform)' == 'macOS'">
    <StrideGraphicsApis Condition="'$(StrideGraphicsApis)' == ''">Vulkan</StrideGraphicsApis>
  </PropertyGroup>

  <!-- ================================================================ -->
  <!-- Configuration Defaults (must be before Output Path) -->
  <!-- ================================================================ -->
  <PropertyGroup>
    <Configuration Condition="'$(Configuration)' == ''">Debug</Configuration>
    <StrideProjectType Condition="'$(MSBuildProjectExtension)' == '.vcxproj'">Cpp</StrideProjectType>
    <StrideProjectType Condition="'$(StrideProjectType)' == ''">CSharp</StrideProjectType>
  </PropertyGroup>

  <!-- ================================================================ -->
  <!-- Output Path Configuration -->
  <!-- ================================================================ -->
  <PropertyGroup>
    <GenerateProjectSpecificOutputFolder>false</GenerateProjectSpecificOutputFolder>
  </PropertyGroup>

  <!-- ================================================================ -->
  <!-- Multi-OS Compatibility -->
  <!-- ================================================================ -->
  <PropertyGroup>
    <!-- Temp directory path for cross-platform builds -->
    <TEMP Condition="'$(TEMP)' == ''">$([System.IO.Path]::GetTempPath())</TEMP>
  </PropertyGroup>

</Project>
