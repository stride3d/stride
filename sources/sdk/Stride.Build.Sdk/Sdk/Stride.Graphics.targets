<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!--
    ================================================================
    Stride.Sdk - Graphics API Build Logic (Stride.Graphics.targets)
    ================================================================

    EVALUATION PHASE: Late (AFTER project file)

    Handles:
    - Graphics API compiler defines (STRIDE_GRAPHICS_API_*)
    - Graphics API list configuration
    - UI framework selection (StrideUI)
    - Design-time build API selection for IntelliSense

    ================================================================
  -->

  <!-- ================================================================ -->
  <!-- Graphics API Lists for Multi-API Builds -->
  <!-- ================================================================ -->
  <PropertyGroup>
    <!-- Build all graphics APIs when StrideGraphicsApiDependent or building all -->
    <StrideGraphicsApis Condition="('$(StrideGraphicsApis)' == '' Or '$(StrideGraphicsApiDependentBuildAll)' == 'true') And ('$(StrideTargetFramework)' == '$(StrideFramework)' Or '$(StrideTargetFramework)' == '$(StrideFrameworkWindows)')">Direct3D11;Direct3D12;Vulkan</StrideGraphicsApis>

    <StrideDefaultGraphicsApi Condition="'$(StrideGraphicsApis)' != ''">$(StrideGraphicsApis.Split(';', StringSplitOptions.RemoveEmptyEntries)[0])</StrideDefaultGraphicsApi>
    <StrideDefaultGraphicsApi Condition="'$(StrideTargetFramework)' == '$(StrideFrameworkUWP)'">Direct3D11</StrideDefaultGraphicsApi>
    <StrideDefaultGraphicsApi Condition="'$(StrideTargetFramework)' == '$(StrideFrameworkAndroid)'">Vulkan</StrideDefaultGraphicsApi>
    <StrideDefaultGraphicsApi Condition="'$(StrideTargetFramework)' == '$(StrideFrameworkiOS)'">Vulkan</StrideDefaultGraphicsApi>
  </PropertyGroup>

  <!-- Some platforms only have a single graphics API.
       If yes, set it right away and disable StrideGraphicsApiDependent (only for inner builds) -->
  <PropertyGroup Condition="'$(StrideGraphicsApiDependent)' == 'true' And !('$(TargetFrameworks)' != '' and '$(TargetFramework)' == '')">
    <StrideGraphicsApiDependent Condition="'$(StrideTargetFramework)' == '$(StrideFrameworkUWP)'">false</StrideGraphicsApiDependent>
    <StrideGraphicsApiDependent Condition="'$(StrideTargetFramework)' == '$(StrideFrameworkiOS)'">false</StrideGraphicsApiDependent>
    <StrideGraphicsApiDependent Condition="'$(StrideTargetFramework)' == '$(StrideFrameworkAndroid)'">false</StrideGraphicsApiDependent>
    <StrideGraphicsApiDependent Condition="'$(StrideTargetFramework)' == '$(StrideFrameworkmacOS)'">false</StrideGraphicsApiDependent>
    <StrideGraphicsApi Condition="'$(StrideGraphicsApiDependent)' == 'false'">$(StrideDefaultGraphicsApi)</StrideGraphicsApi>
  </PropertyGroup>

  <!-- Setup default GraphicsApi for design-time build (IntelliSense) -->
  <PropertyGroup Condition="'$(DesignTimeBuild)' == 'true' And '$(StrideGraphicsApiDependent)' == 'true' And '$(StrideGraphicsApi)' == ''">
    <StrideGraphicsApi Condition="'$(StrideGraphicsApi)' == ''">$(StrideDefaultGraphicsApiDesignTime)</StrideGraphicsApi>
    <StrideGraphicsApi Condition="'$(StrideGraphicsApi)' == ''">$(StrideDefaultGraphicsApi)</StrideGraphicsApi>
  </PropertyGroup>

  <!-- ================================================================ -->
  <!-- Graphics API Compiler Defines -->
  <!-- ================================================================ -->
  <PropertyGroup Condition=" '$(StrideGraphicsApi)' == 'Direct3D11' ">
    <StrideGraphicsApiDefines>STRIDE_GRAPHICS_API_DIRECT3D;STRIDE_GRAPHICS_API_DIRECT3D11</StrideGraphicsApiDefines>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(StrideGraphicsApi)' == 'Direct3D12' ">
    <StrideGraphicsApiDefines>STRIDE_GRAPHICS_API_DIRECT3D;STRIDE_GRAPHICS_API_DIRECT3D12</StrideGraphicsApiDefines>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(StrideGraphicsApi)' == 'Null' ">
    <StrideGraphicsApiDefines>STRIDE_GRAPHICS_API_NULL</StrideGraphicsApiDefines>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(StrideGraphicsApi)' == 'Vulkan' ">
    <StrideGraphicsApiDefines>STRIDE_GRAPHICS_API_VULKAN</StrideGraphicsApiDefines>
  </PropertyGroup>

  <!-- Apply graphics API defines to compiler -->
  <PropertyGroup>
    <DefineConstants Condition="'$(StrideGraphicsApiDefines)' != ''">$(DefineConstants);$(StrideGraphicsApiDefines)</DefineConstants>
  </PropertyGroup>

  <!-- ================================================================ -->
  <!-- Graphics API Output Path Adjustment -->
  <!-- ================================================================ -->
  <!-- Per-API output subdirectory. Test projects using the Stride test SDK override OutputPath
       after this import. $(TargetFramework) is wrapped in a conditional variable so the segment
       collapses cleanly at outer-build (TargetFramework=''). -->
  <PropertyGroup Condition="'$(StrideGraphicsApiDependent)' == 'true'">
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
    <_StrideGraphicsApiTfmSegment Condition="'$(TargetFramework)' != ''">$(TargetFramework)\</_StrideGraphicsApiTfmSegment>
    <IntermediateOutputPath>obj\$(Configuration)\$(_StrideGraphicsApiTfmSegment)$(StrideGraphicsApi)\</IntermediateOutputPath>
    <OutputPath>bin\$(Configuration)\$(_StrideGraphicsApiTfmSegment)$(StrideGraphicsApi)\</OutputPath>
  </PropertyGroup>

  <!-- ================================================================ -->
  <!-- UI Framework Configuration -->
  <!-- ================================================================ -->
  <PropertyGroup>
    <StrideUI Condition="'$(StrideTargetFramework)' != '$(StrideFrameworkUWP)'">SDL</StrideUI>
    <StrideUI Condition="'$(StrideTargetFramework)' == '$(StrideFrameworkWindows)' AND ('$(StrideGraphicsApi)' == 'Direct3D11' Or '$(StrideGraphicsApi)' == 'Direct3D12' Or '$(StrideGraphicsApi)' == 'Vulkan')">$(StrideUI);WINFORMS;WPF</StrideUI>

    <DefineConstants Condition="$(StrideUI.Contains('SDL'))">$(DefineConstants);STRIDE_UI_SDL</DefineConstants>
    <DefineConstants Condition="$(StrideUI.Contains('WINFORMS'))">$(DefineConstants);STRIDE_UI_WINFORMS</DefineConstants>
    <DefineConstants Condition="$(StrideUI.Contains('WPF'))">$(DefineConstants);STRIDE_UI_WPF</DefineConstants>
  </PropertyGroup>

  <!-- Build the StrideUIList using the value of StrideUI -->
  <ItemGroup Condition="'$(StrideUIList)' == ''">
    <StrideUIList Condition="'$(StrideUI)' != ''" Include="$(StrideUI)" />
    <StrideUIList Condition="'$(StrideUI)' == ''" Include="None" />
  </ItemGroup>

  <!-- Download + bundle Vulkan validation layers for Android Debug builds.
       Mirrors the block in engine/Stride.Graphics/build/Stride.Graphics.targets so source-tree
       (ProjectReference) consumers get layers too — engine/build/ only fires for NuGet consumers. -->
  <PropertyGroup Condition="'$(StridePlatform)' == 'Android' And '$(StrideGraphicsApi)' == 'Vulkan' And '$(Configuration)' == 'Debug'">
    <StrideVulkanValidationVersion>1.4.341.0</StrideVulkanValidationVersion>
    <StrideVulkanValidationCacheDir>$(LOCALAPPDATA)\Stride\VulkanValidation\$(StrideVulkanValidationVersion)</StrideVulkanValidationCacheDir>
    <StrideVulkanValidationAbiDir>$(StrideVulkanValidationCacheDir)\android-binaries-$(StrideVulkanValidationVersion)</StrideVulkanValidationAbiDir>
    <StrideVulkanValidationZip>$(StrideVulkanValidationCacheDir)\android-binaries.zip</StrideVulkanValidationZip>
    <StrideVulkanValidationUrl>https://github.com/KhronosGroup/Vulkan-ValidationLayers/releases/download/vulkan-sdk-$(StrideVulkanValidationVersion)/android-binaries-$(StrideVulkanValidationVersion).zip</StrideVulkanValidationUrl>
  </PropertyGroup>

  <!-- Atomic directory rename: Directory.Move is atomic on POSIX (rename(2)) and on Windows
       NTFS (MoveFileEx with MOVEFILE_REPLACE_EXISTING off). Used as the cross-process commit
       point of the temp-extract pattern in _StrideDownloadVulkanValidationLayers — the loser
       of a parallel race throws IOException and noops. -->
  <UsingTask TaskName="StrideAtomicDirectoryMove" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <Source ParameterType="System.String" Required="true" />
      <Destination ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Code Type="Fragment" Language="cs"><![CDATA[
        try { System.IO.Directory.Move(Source, Destination); }
        catch (System.IO.IOException) { /* destination exists -- another process beat us */ }
      ]]></Code>
    </Task>
  </UsingTask>

  <!-- Parallel-safe: every Android project hits this target concurrently. Per-invocation
       temp files isolate the download and the extract; atomic Move/Directory.Move commits
       the result. Re-check the extracted-layer marker before each expensive step so once any
       process has populated the cache, the rest skip straight through. -->
  <Target Name="_StrideDownloadVulkanValidationLayers"
          Condition="'$(StridePlatform)' == 'Android' And '$(StrideGraphicsApi)' == 'Vulkan' And '$(Configuration)' == 'Debug' And !Exists('$(StrideVulkanValidationAbiDir)\arm64-v8a\libVkLayer_khronos_validation.so')"
          BeforeTargets="_ResolveLibraryProjectImports">
    <PropertyGroup>
      <_StrideVkValidTmpZip>$(StrideVulkanValidationCacheDir)\android-binaries.$([System.Guid]::NewGuid()).tmp</_StrideVkValidTmpZip>
      <_StrideVkValidTmpExtract>$(StrideVulkanValidationCacheDir)\extract.$([System.Guid]::NewGuid()).tmp</_StrideVkValidTmpExtract>
    </PropertyGroup>
    <Message Importance="high" Text="Downloading Vulkan validation layers $(StrideVulkanValidationVersion)..." />
    <MakeDir Directories="$(StrideVulkanValidationCacheDir)" />
    <DownloadFile Condition="!Exists('$(StrideVulkanValidationAbiDir)\arm64-v8a\libVkLayer_khronos_validation.so') And !Exists('$(StrideVulkanValidationZip)')"
                  SourceUrl="$(StrideVulkanValidationUrl)" DestinationFolder="$(StrideVulkanValidationCacheDir)"
                  DestinationFileName="$([System.IO.Path]::GetFileName('$(_StrideVkValidTmpZip)'))" />
    <Move Condition="Exists('$(_StrideVkValidTmpZip)') And !Exists('$(StrideVulkanValidationZip)')"
          SourceFiles="$(_StrideVkValidTmpZip)" DestinationFiles="$(StrideVulkanValidationZip)" />
    <Delete Condition="Exists('$(_StrideVkValidTmpZip)')" Files="$(_StrideVkValidTmpZip)" />
    <Unzip Condition="!Exists('$(StrideVulkanValidationAbiDir)\arm64-v8a\libVkLayer_khronos_validation.so')"
           SourceFiles="$(StrideVulkanValidationZip)" DestinationFolder="$(_StrideVkValidTmpExtract)" OverwriteReadOnlyFiles="true" />
    <StrideAtomicDirectoryMove Condition="Exists('$(_StrideVkValidTmpExtract)\android-binaries-$(StrideVulkanValidationVersion)') And !Exists('$(StrideVulkanValidationAbiDir)')"
                               Source="$(_StrideVkValidTmpExtract)\android-binaries-$(StrideVulkanValidationVersion)"
                               Destination="$(StrideVulkanValidationAbiDir)" />
    <RemoveDir Condition="Exists('$(_StrideVkValidTmpExtract)')" Directories="$(_StrideVkValidTmpExtract)" />
  </Target>

  <!-- Only add the layers to APK-producing projects (AndroidApplication=true). Without this
       gate every Android class library bundles the ~93 MB layer set into its .aar, blowing
       up build time and causing parallel-build .aar file lock races between consumers. -->
  <ItemGroup Condition="'$(StridePlatform)' == 'Android' And '$(StrideGraphicsApi)' == 'Vulkan' And '$(Configuration)' == 'Debug' And '$(AndroidApplication)' == 'true'">
    <AndroidNativeLibrary Include="$(StrideVulkanValidationAbiDir)\arm64-v8a\libVkLayer_khronos_validation.so" Condition="Exists('$(StrideVulkanValidationAbiDir)\arm64-v8a\libVkLayer_khronos_validation.so')">
      <Abi>arm64-v8a</Abi>
    </AndroidNativeLibrary>
    <AndroidNativeLibrary Include="$(StrideVulkanValidationAbiDir)\armeabi-v7a\libVkLayer_khronos_validation.so" Condition="Exists('$(StrideVulkanValidationAbiDir)\armeabi-v7a\libVkLayer_khronos_validation.so')">
      <Abi>armeabi-v7a</Abi>
    </AndroidNativeLibrary>
    <AndroidNativeLibrary Include="$(StrideVulkanValidationAbiDir)\x86_64\libVkLayer_khronos_validation.so" Condition="Exists('$(StrideVulkanValidationAbiDir)\x86_64\libVkLayer_khronos_validation.so')">
      <Abi>x86_64</Abi>
    </AndroidNativeLibrary>
    <AndroidNativeLibrary Include="$(StrideVulkanValidationAbiDir)\x86\libVkLayer_khronos_validation.so" Condition="Exists('$(StrideVulkanValidationAbiDir)\x86\libVkLayer_khronos_validation.so')">
      <Abi>x86</Abi>
    </AndroidNativeLibrary>
  </ItemGroup>

</Project>
