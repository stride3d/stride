<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!--
    ================================================================
    Stride.Dependencies.targets - Native Dependency System (.ssdeps)
    ================================================================

    Manages native libraries that travel alongside managed assemblies via .ssdeps manifest
    files. Two workflows:
      1. READING: when referencing assemblies that have .ssdeps siblings, reads them and
         either copies natives to output (desktop) or hands them to platform-specific item
         types (NativeReference / AndroidNativeLibrary).
      2. WRITING: when a project declares StrideNativeLib items, writes a .ssdeps next to the
         produced assembly and copies natives into the output's runtimes/<rid>/native/ tree.

    Platform-specific consumption:
    - Desktop (Windows/Linux/macOS): natives copied to output runtime asset path.
    - macOS (-macos TFM): emitted as NativeReference Kind=Dynamic so dylibs end up in
      Contents/MonoBundle/ of the .app bundle alongside NuGet RID assets.
    - Android: emitted as AndroidNativeLibrary with the RID→ABI name mapping; engine
      self-build only — NuGet PackageReference consumers get this for free via
      Microsoft.Android.Sdk auto-conversion of runtimes/android-*/native/*.so.
    - iOS: emitted as NativeReference Kind=Static ForceLoad=True via the shared target in
      Stride.Core.NativeLibraries.targets, which also handles the NuGet PackageReference
      path by sourcing items from @(RuntimeCopyLocalItems).
    ================================================================
  -->

  <PropertyGroup>
    <AllowedOutputExtensionsInPackageBuildOutputFolder>.ssdeps; $(AllowedOutputExtensionsInPackageBuildOutputFolder)</AllowedOutputExtensionsInPackageBuildOutputFolder>
    <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);_StrideRegisterDependenciesOutputs</TargetsForTfmSpecificBuildOutput>
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);_StrideRegisterPackageFiles</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <!-- ================================================================ -->
  <!-- Dependencies reading (from .ssdeps)                              -->
  <!-- ================================================================ -->

  <!-- List dependency files from .ssdeps -->
  <!-- When the current build targets a specific StrideGraphicsApi, drop candidate paths whose
       parent directory is a non-current API folder. Otherwise a non-API-dependent middle project
       (say Stride.Engine, built with default API=Direct3D11) re-exports its CopyLocal'd
       Stride.Graphics.ssdeps through the reference graph, and the direct API-dependent reference
       also provides one — both land on the same filename in the output folder and race. -->
  <Target Name="_StrideListDepsFiles" DependsOnTargets="ResolveAssemblyReferences">
    <ItemGroup>
      <_StrideDepsFile Include="@(ReferencePath->'%(RootDir)%(Directory)%(Filename).ssdeps')" Condition="'%(ReferencePath.CopyLocal)' != 'false' And Exists('%(RootDir)%(Directory)%(Filename).ssdeps')"/>
      <_StrideDepsFile Include="@(ReferenceDependencyPaths->'%(RootDir)%(Directory)%(Filename).ssdeps')" Condition="'%(ReferenceDependencyPaths.CopyLocal)' != 'false' And Exists('%(RootDir)%(Directory)%(Filename).ssdeps')"/>
    </ItemGroup>
    <ItemGroup Condition="'$(StrideGraphicsApi)' != ''">
      <!-- Path-separator check normalized to '/' so Linux/macOS hosts filter correctly. -->
      <_StrideDepsFile Remove="@(_StrideDepsFile)" Condition="$([System.String]::Copy('%(Identity)').Replace('\','/').Contains('/Direct3D11/')) And '$(StrideGraphicsApi)' != 'Direct3D11'" />
      <_StrideDepsFile Remove="@(_StrideDepsFile)" Condition="$([System.String]::Copy('%(Identity)').Replace('\','/').Contains('/Direct3D12/')) And '$(StrideGraphicsApi)' != 'Direct3D12'" />
      <_StrideDepsFile Remove="@(_StrideDepsFile)" Condition="$([System.String]::Copy('%(Identity)').Replace('\','/').Contains('/Vulkan/')) And '$(StrideGraphicsApi)' != 'Vulkan'" />
      <_StrideDepsFile Remove="@(_StrideDepsFile)" Condition="$([System.String]::Copy('%(Identity)').Replace('\','/').Contains('/OpenGL/')) And '$(StrideGraphicsApi)' != 'OpenGL'" />
      <_StrideDepsFile Remove="@(_StrideDepsFile)" Condition="$([System.String]::Copy('%(Identity)').Replace('\','/').Contains('/OpenGLES/')) And '$(StrideGraphicsApi)' != 'OpenGLES'" />
    </ItemGroup>
    <ItemGroup>
      <None Include="@(_StrideDepsFile)" CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>
  </Target>

  <!-- Filter transitive CopyToOutput items coming from non-API-dependent project references.
       They would otherwise pull the default-API variant (e.g. Direct3D11) of API-dependent
       side files (Stride.Graphics.ssdeps, Stride.VirtualReality.ssdeps, and the native libs
       they manifest) through the reference graph, colliding in the consumer's output folder
       with the direct API-dependent reference's correct variant. -->
  <Target Name="_StrideFilterTransitiveCopyToOutputDirectoryItems"
          BeforeTargets="_CopyOutOfDateSourceItemsToOutputDirectory;_CopyOutOfDateSourceItemsToOutputDirectoryAlways"
          DependsOnTargets="GetCopyToOutputDirectoryItems"
          Condition="'$(StrideGraphicsApi)' != ''">
    <ItemGroup>
      <_SourceItemsToCopyToOutputDirectory Remove="@(_SourceItemsToCopyToOutputDirectory)" Condition="$([System.String]::Copy('%(Identity)').Contains('\Direct3D11\')) And '$(StrideGraphicsApi)' != 'Direct3D11'" />
      <_SourceItemsToCopyToOutputDirectory Remove="@(_SourceItemsToCopyToOutputDirectory)" Condition="$([System.String]::Copy('%(Identity)').Contains('\Direct3D12\')) And '$(StrideGraphicsApi)' != 'Direct3D12'" />
      <_SourceItemsToCopyToOutputDirectory Remove="@(_SourceItemsToCopyToOutputDirectory)" Condition="$([System.String]::Copy('%(Identity)').Contains('\Vulkan\')) And '$(StrideGraphicsApi)' != 'Vulkan'" />
      <_SourceItemsToCopyToOutputDirectory Remove="@(_SourceItemsToCopyToOutputDirectory)" Condition="$([System.String]::Copy('%(Identity)').Contains('\OpenGL\')) And '$(StrideGraphicsApi)' != 'OpenGL'" />
      <_SourceItemsToCopyToOutputDirectory Remove="@(_SourceItemsToCopyToOutputDirectory)" Condition="$([System.String]::Copy('%(Identity)').Contains('\OpenGLES\')) And '$(StrideGraphicsApi)' != 'OpenGLES'" />
    </ItemGroup>
  </Target>

  <!-- _StrideReadDepsFiles + _StrideDistinctByFilename UsingTasks, _StrideBuildDependencies
       (.ssdeps parser), and the iOS NativeReference target all live in the shared file so
       Stride.Core.targets (NuGet PackageReference path) and this (engine self-build path)
       use one implementation. -->
  <Import Project="$(StrideRoot)sources/core/Stride.Core/build/Stride.Core.NativeLibraries.targets" />

  <!-- ================================================================ -->
  <!-- Native libraries setup (from .ssdeps)                            -->
  <!-- ================================================================ -->
  <!-- The natural fit would be <None Include=...> with BeforeTargets="AssignTargetPaths" so the
       .NET pipeline picks them up via GetCopyToOutputDirectoryItems, but that creates a cycle
       through our DependsOn chain (_StrideListDepsFiles needs ResolveAssemblyReferences, which
       transitively brings AssignTargetPaths back through it). Instead we wait until GCTODI has
       run and contribute directly to _SourceItemsToCopyToOutputDirectory — same as the
       _StrideFilterAndFlattenRuntimes target in Stride.Build.Sdk.Tests does. -->
  <Target Name="_StrideSetupNativeLibraries" DependsOnTargets="_StrideBuildDependencies;GetCopyToOutputDirectoryItems"
          BeforeTargets="_CopyOutOfDateSourceItemsToOutputDirectory;_CopyOutOfDateSourceItemsToOutputDirectoryAlways;_CopyFilesMarkedCopyLocal"
          Condition="'$(StrideDependenciesCopy)' != 'false'">
    <!-- net10.0-macos also copies to the output dir: the .app gets dylibs via NativeReference
         below, but test hosts (vstest) run the bare output dir and dlopen from there. -->
    <ItemGroup Condition=" '$(StrideTargetFramework)' == '$(StrideFramework)' Or '$(StrideTargetFramework)' == '$(StrideFrameworkWindows)' Or '$(StrideTargetFramework)' == '$(StrideFrameworkmacOS)' ">
      <!-- When RuntimeIdentifier is set, drop runtimes/<rid'>/native/X items whose <rid'> isn't ours
           and flatten the kept ones to the output root (matching .NET's RID-aware NuGet flattening).
           NativeLibraryHelper probes both the runtimes/<rid>/native/ subdir and the bare root, so
           both layouts resolve. -->
      <!-- .ssdeps is normalized to '/' at write time (see _StrideGenerateDependenciesCore), so this
           is a plain substring check — no path-separator normalization needed at read time. -->
      <_StrideDependencyNativeLibFiltered Include="@(_StrideDependencyNativeLib)"
          Condition="'$(RuntimeIdentifier)' == '' Or $([System.String]::Copy('%(_StrideDependencyNativeLib.Link)').Contains('/$(RuntimeIdentifier)/'))" />
      <_SourceItemsToCopyToOutputDirectory Include="@(_StrideDependencyNativeLibFiltered)">
        <TargetPath Condition="'$(RuntimeIdentifier)' == ''">%(_StrideDependencyNativeLibFiltered.Link)</TargetPath>
        <TargetPath Condition="'$(RuntimeIdentifier)' != ''">%(_StrideDependencyNativeLibFiltered.Filename)%(_StrideDependencyNativeLibFiltered.Extension)</TargetPath>
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </_SourceItemsToCopyToOutputDirectory>
    </ItemGroup>

    <!-- macOS: emit NativeReference Kind=Dynamic so dylibs land in Contents/MonoBundle alongside the NuGet runtime assets. -->
    <ItemGroup Condition=" '$(StrideTargetFramework)' == '$(StrideFrameworkmacOS)' ">
      <_StrideMacOSNativeRef Include="@(_StrideDependencyNativeLib)"
          Condition="'%(_StrideDependencyNativeLib.Extension)' == '.dylib' And ('$(RuntimeIdentifier)' == '' Or $([System.String]::Copy('%(_StrideDependencyNativeLib.Link)').Contains('/$(RuntimeIdentifier)/')))" />
    </ItemGroup>
    <_StrideDistinctByFilename Items="@(_StrideMacOSNativeRef)" Condition=" '$(StrideTargetFramework)' == '$(StrideFrameworkmacOS)' And '@(_StrideMacOSNativeRef)' != '' ">
      <Output TaskParameter="Distinct" ItemName="_StrideMacOSNativeRefUnique" />
    </_StrideDistinctByFilename>
    <ItemGroup Condition=" '$(StrideTargetFramework)' == '$(StrideFrameworkmacOS)' ">
      <NativeReference Include="@(_StrideMacOSNativeRefUnique)">
        <Kind>Dynamic</Kind>
        <SmartLink>False</SmartLink>
      </NativeReference>
    </ItemGroup>

    <!-- iOS NativeReference wiring lives in Stride.Core.NativeLibraries.targets
         (imported at the top of this file) — its needs are identical between the
         engine self-build path here and the NuGet PackageReference path. -->
  </Target>

  <!-- StrideToolingHost (AssetCompiler, GameStudio): drop runtimes/<rid>/ assets that this desktop
       host can't use from its no-RID output — mobile (android/ios/tvos, ~250 MB) on net10.0, plus
       linux/osx on the Windows-only net10.0-windows. Covers NuGet assets (ReferenceCopyLocalPaths),
       .ssdeps natives and Content copies (_SourceItemsToCopyToOutputDirectory[Always]); items outside
       runtimes/ are untouched. Normalize '\'→'/' — Replace('/','\\') yields a double backslash here,
       so 'runtimes/win-x64' would fail StartsWith('runtimes\win') and drop the win natives. -->
  <Target Name="_StrideTrimToolingHostRuntimeAssets"
          DependsOnTargets="GetCopyToOutputDirectoryItems"
          BeforeTargets="_CopyOutOfDateSourceItemsToOutputDirectory;_CopyOutOfDateSourceItemsToOutputDirectoryAlways;_CopyFilesMarkedCopyLocal"
          Condition="'$(StrideToolingHost)' == 'true' And '$(RuntimeIdentifier)' == ''">
    <ItemGroup>
      <ReferenceCopyLocalPaths Remove="@(ReferenceCopyLocalPaths)"
          Condition="$([System.String]::Copy('%(ReferenceCopyLocalPaths.DestinationSubPath)').Replace('\','/').StartsWith('runtimes/'))
                     And !$([System.String]::Copy('%(ReferenceCopyLocalPaths.DestinationSubPath)').Replace('\','/').StartsWith('runtimes/win'))
                     And ('$(StrideTargetFramework)' == '$(StrideFrameworkWindows)'
                          Or (!$([System.String]::Copy('%(ReferenceCopyLocalPaths.DestinationSubPath)').Replace('\','/').StartsWith('runtimes/linux'))
                              And !$([System.String]::Copy('%(ReferenceCopyLocalPaths.DestinationSubPath)').Replace('\','/').StartsWith('runtimes/osx'))))" />
      <_SourceItemsToCopyToOutputDirectory Remove="@(_SourceItemsToCopyToOutputDirectory)"
          Condition="$([System.String]::Copy('%(_SourceItemsToCopyToOutputDirectory.TargetPath)').Replace('\','/').StartsWith('runtimes/'))
                     And !$([System.String]::Copy('%(_SourceItemsToCopyToOutputDirectory.TargetPath)').Replace('\','/').StartsWith('runtimes/win'))
                     And ('$(StrideTargetFramework)' == '$(StrideFrameworkWindows)'
                          Or (!$([System.String]::Copy('%(_SourceItemsToCopyToOutputDirectory.TargetPath)').Replace('\','/').StartsWith('runtimes/linux'))
                              And !$([System.String]::Copy('%(_SourceItemsToCopyToOutputDirectory.TargetPath)').Replace('\','/').StartsWith('runtimes/osx'))))" />
      <_SourceItemsToCopyToOutputDirectoryAlways Remove="@(_SourceItemsToCopyToOutputDirectoryAlways)"
          Condition="$([System.String]::Copy('%(_SourceItemsToCopyToOutputDirectoryAlways.TargetPath)').Replace('\','/').StartsWith('runtimes/'))
                     And !$([System.String]::Copy('%(_SourceItemsToCopyToOutputDirectoryAlways.TargetPath)').Replace('\','/').StartsWith('runtimes/win'))
                     And ('$(StrideTargetFramework)' == '$(StrideFrameworkWindows)'
                          Or (!$([System.String]::Copy('%(_SourceItemsToCopyToOutputDirectoryAlways.TargetPath)').Replace('\','/').StartsWith('runtimes/linux'))
                              And !$([System.String]::Copy('%(_SourceItemsToCopyToOutputDirectoryAlways.TargetPath)').Replace('\','/').StartsWith('runtimes/osx'))))" />
    </ItemGroup>
  </Target>

  <!-- Track deployed native libraries in the fast up-to-date check as copied outputs, each paired with its
       source via Original metadata. Unlike a plain UpToDateCheckInput, the re-copy on rebuild makes the output
       at least as new as the source, so the check clears instead of looping; and a changed vendored binary
       rebuilds and re-deploys. Emitted in the design-time built collection (references are resolved there); the
       depended-on targets only read .ssdeps and compute item paths, so there are no file-system side effects. -->
  <PropertyGroup>
    <CollectUpToDateCheckBuiltDesignTimeDependsOn>$(CollectUpToDateCheckBuiltDesignTimeDependsOn);_StrideCollectNativeUpToDateCheckBuilt</CollectUpToDateCheckBuiltDesignTimeDependsOn>
  </PropertyGroup>
  <Target Name="_StrideCollectNativeUpToDateCheckBuilt"
          DependsOnTargets="_StrideSetupNativeLibraries;_StrideFilterTransitiveCopyToOutputDirectoryItems;_StrideTrimToolingHostRuntimeAssets">
    <!-- This project's own StrideNativeLib, deployed to its output by _StrideGenerateDependenciesCore. -->
    <AssignTargetPath RootFolder="$(OutputPath)" Files="@(StrideNativeLib)">
      <Output TaskParameter="AssignedFiles" ItemName="_StrideNativeLibBuiltCheck" />
    </AssignTargetPath>
    <ItemGroup>
      <UpToDateCheckBuilt Include="@(_StrideNativeLibBuiltCheck->'$(OutDir)%(TargetPath)')" Original="%(_StrideNativeLibBuiltCheck.FullPath)" />
      <!-- Natives copied in from referenced .ssdeps, after RID filtering and tooling-host trimming. -->
      <UpToDateCheckBuilt Include="@(_SourceItemsToCopyToOutputDirectory->'$(OutDir)%(TargetPath)')"
                          Original="%(_SourceItemsToCopyToOutputDirectory.FullPath)"
                          Condition="$([System.String]::Copy('%(_SourceItemsToCopyToOutputDirectory.TargetPath)').Replace('\','/').StartsWith('runtimes/'))" />
    </ItemGroup>
  </Target>

  <!-- Android (engine self-build only): .ssdeps points natives at deps/<Lib>/Android/<abi>/
       which Microsoft.Android.Sdk's standard NuGet runtimes/<rid>/native/ resolver doesn't
       see. NuGet PackageReference consumers don't need this — Microsoft.Android.Sdk picks
       up runtimes/android-*/native/*.so from RuntimeCopyLocalItems automatically.

       Hooked at BOTH _CompileFastDevDex (Fast Deploy path, captures @(AndroidNativeLibrary)
       into _AndroidNativeLibraryForFastDev) and _GetLibraryImports (embed path) — running
       inside CoreBuild's _CopyFilesToOutputDirectory chain like the desktop branch isn't
       early enough for the .NET Android SDK's per-target item capture, leaving Fast Deploy
       APKs missing .ssdeps-sourced libs (libstrideaudio, libfreetype, etc.).
       .ssdeps writes Identity with '/' so we match on '/'; AndroidNativeLibrary needs the
       Abi metadata set explicitly — RID name (android-arm/-arm64/-x86/-x64) doesn't match
       ABI name (armeabi-v7a / arm64-v8a / x86 / x86_64) for two of the four. -->
  <Target Name="_StrideAddAndroidNativeLibraries"
          DependsOnTargets="_StrideBuildDependencies"
          BeforeTargets="_CompileFastDevDex;_GetLibraryImports"
          Condition=" '$(StrideTargetFramework)' == '$(StrideFrameworkAndroid)' And '$(StrideDependenciesCopy)' != 'false' ">
    <ItemGroup>
      <AndroidNativeLibrary Include="@(_StrideDependencyNativeLib)"
          Condition="$([System.String]::new('%(Identity)').Contains('runtimes/android-'))" />
      <AndroidNativeLibrary Update="@(AndroidNativeLibrary)" Abi="armeabi-v7a"
          Condition="$([System.String]::new('%(Identity)').Contains('runtimes/android-arm/'))" />
      <AndroidNativeLibrary Update="@(AndroidNativeLibrary)" Abi="arm64-v8a"
          Condition="$([System.String]::new('%(Identity)').Contains('runtimes/android-arm64/'))" />
      <AndroidNativeLibrary Update="@(AndroidNativeLibrary)" Abi="x86"
          Condition="$([System.String]::new('%(Identity)').Contains('runtimes/android-x86/'))" />
      <AndroidNativeLibrary Update="@(AndroidNativeLibrary)" Abi="x86_64"
          Condition="$([System.String]::new('%(Identity)').Contains('runtimes/android-x64/'))" />
    </ItemGroup>
  </Target>

  <!-- ================================================================ -->
  <!-- Dependencies generation (to .ssdeps)                             -->
  <!-- ================================================================ -->
  <Target Name="_StrideGenerateDependenciesCore">
    <AssignTargetPath RootFolder="$(OutputPath)" Files="@(StrideNativeLib)">
      <Output TaskParameter="AssignedFiles" ItemName="_StrideNativeLibAssigned"/>
    </AssignTargetPath>

    <ItemGroup>
      <_StrideDependencyToCopy Include="@(_StrideNativeLibAssigned)">
        <Type>NativeLib</Type>
        <Destination>$(OutDir)%(TargetPath)</Destination>
      </_StrideDependencyToCopy>

      <_StrideDependencyToCopy Remove="@(_StrideNativeLibAssigned)" Condition=" '$(StridePackageBuild)' == 'true' And '%(_StrideNativeLibAssigned.Extension)' == '.pdb' "/>
    </ItemGroup>

    <!-- Normalize TargetPath to forward slashes for .ssdeps emission. AssignTargetPath
         uses the host's directory separator, so a Windows-built NuGet would otherwise ship .ssdeps
         entries with '\' that don't match a macOS/Linux consumer's substring checks. Pinning one
         separator at write time lets every reader assume '/' without normalization. -->
    <ItemGroup>
      <_StrideDependencyToCopy>
        <TargetPathNormalized>$([System.String]::Copy('%(TargetPath)').Replace('\','/'))</TargetPathNormalized>
      </_StrideDependencyToCopy>
    </ItemGroup>

    <!-- Copy files -->
    <Copy
      SourceFiles = "@(_StrideDependencyToCopy)"
      DestinationFiles = "@(_StrideDependencyToCopy->'%(Destination)')"
      OverwriteReadOnlyFiles="$(OverwriteReadOnlyFiles)"
      Retries="$(CopyRetryCount)"
      RetryDelayMilliseconds="$(CopyRetryDelayMilliseconds)"
      UseHardlinksIfPossible="$(CreateHardLinksForAdditionalFilesIfPossible)">
      <Output TaskParameter="DestinationFiles" ItemName="FileWrites"/>
    </Copy>

    <!-- Write file containing list of dependent files (or delete it if nothing) -->
    <!-- Format: "Type;Path". The reader derives the deployment Link from Path (strips leading "./").
         Older .ssdeps files had a third column duplicating Path; the reader tolerates it but
         ignores it, so we don't emit it anymore. -->
    <WriteLinesToFile Condition="'@(_StrideDependencyToCopy)' != ''" File="$(OutputPath)$(TargetName).ssdeps" Lines="@(_StrideDependencyToCopy->'%(Type);%(TargetPathNormalized)')" Overwrite="true"/>
    <Delete Condition="'@(_StrideDependencyToCopy)' == ''" Files="$(OutputPath)$(TargetName).ssdeps"/>
  </Target>

  <!-- Build -->
  <Target Name="_StrideGenerateDependencies" Condition="'$(TargetFramework)' != '' Or '$(StrideProjectType)' == 'Cpp'" DependsOnTargets="_StrideGenerateDependenciesCore" AfterTargets="CopyFilesToOutputDirectory"/>
  <!-- Packaging -->
  <Target Name="_StrideRegisterDependenciesOutputs" Condition="'$(TargetFramework)' != ''" DependsOnTargets="_StrideGenerateDependenciesCore">
    <ItemGroup Condition="'@(_StrideDependencyToCopy)' != ''">
      <BuildOutputInPackage Include="$(OutputPath)$(AssemblyName).ssdeps" />
    </ItemGroup>
  </Target>
  <Target Name="_StrideRegisterPackageFiles" Condition="'$(TargetFramework)' != ''" DependsOnTargets="_StrideGenerateDependenciesCore">
    <ItemGroup Condition="'@(_StrideDependencyToCopy)' != ''">
      <!-- Native dependencies go to the runtimes/RID/native folder -->
      <TfmSpecificPackageFile Include="@(_StrideDependencyToCopy)"
                              PackagePath="%(_StrideDependencyToCopy.TargetPath)" />
    </ItemGroup>
  </Target>

</Project>
