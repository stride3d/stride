<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Define default frameworks for each target -->
  <PropertyGroup>
    <StrideFramework>net10.0</StrideFramework>
    <StrideFrameworkAndroid>net10.0-android</StrideFrameworkAndroid>
    <StrideFrameworkiOS>net10.0-ios</StrideFrameworkiOS>
    <StrideFrameworkUWP>uap10.0.16299</StrideFrameworkUWP>
    <StrideFrameworkWindows>net10.0-windows</StrideFrameworkWindows>
    <StrideFrameworkmacOS>net10.0-macos</StrideFrameworkmacOS>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
  </PropertyGroup>

  <!-- StrideTargetFramework collapses any platform-version suffix on TargetFramework down to
       the family constant: net10.0-windows10.0.19041.0 → net10.0-windows. SDK conditions
       compare against this so a project can opt into a versioned OS moniker (e.g. for
       WinRT projection access) without breaking platform/dependency setup. -->
  <PropertyGroup>
    <StrideTargetFramework>$(TargetFramework)</StrideTargetFramework>
    <StrideTargetFramework Condition="$(TargetFramework.StartsWith('$(StrideFrameworkWindows)'))">$(StrideFrameworkWindows)</StrideTargetFramework>
    <StrideTargetFramework Condition="$(TargetFramework.StartsWith('$(StrideFrameworkAndroid)'))">$(StrideFrameworkAndroid)</StrideTargetFramework>
    <StrideTargetFramework Condition="$(TargetFramework.StartsWith('$(StrideFrameworkiOS)'))">$(StrideFrameworkiOS)</StrideTargetFramework>
    <StrideTargetFramework Condition="$(TargetFramework.StartsWith('$(StrideFrameworkmacOS)'))">$(StrideFrameworkmacOS)</StrideTargetFramework>
  </PropertyGroup>

</Project>