<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!--
    ================================================================
    Stride.Sdk - Build Logic and Targets (Sdk.targets)
    ================================================================

    EVALUATION ORDER: This file is imported AFTER the project file!

    What you CAN do here:
    - Check user-defined properties from .csproj (now visible!)
    - Compute derived properties based on user values
    - Conditionally enable features based on user properties
    - Define build targets and tasks

    What you should do here:
    - All conditional logic that depends on .csproj properties
    - Property computation based on user choices
    - Target framework expansion (StrideRuntime → TargetFrameworks)
    - Build customization based on user configuration

    Rule: User properties from .csproj ARE visible here.
          This is where conditional logic belongs.

    See: docs/build/SDK-GUIDE.md#property-evaluation-order
    ================================================================
  -->

  <!-- ================================================================ -->
  <!-- Import supporting targets files -->
  <!-- ================================================================ -->
  <Import Project="Stride.Frameworks.targets" />
  <Import Project="Stride.Platform.targets" />
  <Import Project="Stride.Graphics.targets" />
  <Import Project="Stride.AssemblyProcessor.targets" />
  <Import Project="Stride.CodeAnalysis.targets" />
  <Import Project="Stride.PackageInfo.targets" />
  <Import Project="$(StrideRoot)sources\targets\Stride.WorktreeVersion.targets" Condition="'$(_StrideWorktreeVersionTargetsImported)' != 'true'" />

  <!-- ================================================================ -->
  <!-- Disable ValidateExecutableReferences -->
  <!-- ================================================================ -->
  <!-- Stride's graphics API inner build system (_ComputeTargetFrameworkItems
       override) creates multiple inner build entries per TFM — one per
       graphics API.  The .NET SDK's ValidateExecutableReferences task
       calls .Single() on entries filtered by TFM, which crashes when
       multiple graphics-API variants share the same TFM. -->
  <PropertyGroup>
    <ValidateExecutableReferencesMatchSelfContained>false</ValidateExecutableReferencesMatchSelfContained>
  </PropertyGroup>

  <!-- ================================================================ -->
  <!-- Import base Microsoft.NET.Sdk targets -->
  <!-- ================================================================ -->
  <!-- This gives us all standard .NET SDK functionality -->
  <Import Project="Sdk.targets" Sdk="Microsoft.NET.Sdk" />

  <!-- ================================================================ -->
  <!-- Graphics API inner build dispatching (multi-API builds) -->
  <!-- ================================================================ -->
  <!-- MUST come after Microsoft.NET.Sdk Sdk.targets because it overrides
       _ComputeTargetFrameworkItems and _WalkEachTargetPerFramework -->
  <Import Project="Stride.GraphicsApi.InnerBuild.targets" />

  <!-- ================================================================ -->
  <!-- Graphics API consumer-side targets (shared with NuGet consumers) -->
  <!-- ================================================================ -->
  <!-- Lives in Stride.Graphics/build/ because the same file is packed into
       the Stride.Graphics NuGet's build/ and buildTransitive/ folders for
       external consumers. Importing it here also gives internal Stride
       builds (which consume Silk.NET native packages directly via
       PackageReference) the same per-API native asset trimming. -->
  <Import Project="$(StrideRoot)sources/engine/Stride.Graphics/build/Stride.GraphicsApiSpecificPackages.targets" />

  <!-- ================================================================ -->
  <!-- Native dependency system (.ssdeps) -->
  <!-- ================================================================ -->
  <Import Project="Stride.Dependencies.targets" />

  <!-- ================================================================ -->
  <!-- Native build mode configuration (Clang/MSVC selection) -->
  <!-- ================================================================ -->
  <Import Project="Stride.NativeBuildMode.props" />

  <!-- Native C/C++ compilation (when StrideNativeOutputName is set) -->
  <Import Condition="'$(StrideNativeOutputName)' != ''" Project="$(StrideRoot)sources\native\Stride.Native.targets" />

  <!-- ================================================================ -->
  <!-- Shader Code Generation Support -->
  <!-- ================================================================ -->
  <!-- Auto-discover .sdsl/.sdfx files, register them as AdditionalFiles for the
       Roslyn source generator, mark generated .cs as dependent, and tag the files
       with the VS Custom Tool generator for older projects that still use it.
       Projects that contain .sdsl/.sdfx files as test inputs or other non-shader
       content can set EnableDefaultStrideShaderItems=false to opt out. -->
  <PropertyGroup>
    <EnableDefaultStrideShaderItems Condition="'$(EnableDefaultStrideShaderItems)' == ''">true</EnableDefaultStrideShaderItems>
  </PropertyGroup>
  <ItemGroup Condition="'$(EnableDefaultStrideShaderItems)' == 'true'">
    <None Remove="**\*.sdsl" />
    <None Remove="**\*.sdfx" />
    <StrideShaderFiles Include="**\*.sdsl" Exclude="$(DefaultItemExcludes);$(DefaultExcludesInProjectFolder)" />
    <StrideShaderFiles Include="**\*.sdfx" Exclude="$(DefaultItemExcludes);$(DefaultExcludesInProjectFolder)" />
    <AdditionalFiles Include="@(StrideShaderFiles)" />
    <ProjectReference Condition="'@(StrideShaderFiles)' != ''" Include="$(StrideRoot)sources\shaders\Stride.Shaders.Generators\Stride.Shaders.Generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!-- ================================================================ -->
  <!-- Stride.Core.CompilerServices Roslyn Analyzer -->
  <!-- ================================================================ -->
  <!-- Stride.Core.CompilerServices is single-TF (netstandard2.0), so an explicit
       SetTargetFramework is redundant — and harmful: it forces TargetFramework into the
       consumer-ref dispatch globals, producing a cache key distinct from the slnf-direct
       outer dispatch (which has no TF global). Both then race on obj/. -->
  <ItemGroup Condition="!$(MSBuildProjectName.StartsWith('Stride.Core.CompilerServices'))">
    <ProjectReference Include="$(StrideRoot)sources\core\Stride.Core.CompilerServices\Stride.Core.CompilerServices.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!-- ================================================================ -->
  <!-- Strip per-RID compute globals from ProjectReference dispatches    -->
  <!-- ================================================================ -->
  <!-- Microsoft.Android.Sdk.AssemblyResolution.targets _ResolveAssemblies dispatches the
       outer Android build to itself with _ComputeFilesToPublishForRuntimeIdentifiers=true and
       a bag of _Outer* / Skip* / AppendRuntimeIdentifierToOutputPath / DesignTimeBuild=false
       globals to compute publish files per RID. Those globals propagate through every
       transitive ProjectReference as inherited global properties, producing a second MSBuild
       build-cache key for every shared dependency (Stride.Engine -> Stride.VirtualReality,
       Stride.Navigation -> Stride.Physics, ...). When test projects build in parallel, the
       resulting concurrent dispatches collide on the shared dep's obj/ — MSB3030 "X.dll not
       found", file lock contention on Stride.X.GeneratedMSBuildEditorConfig.editorconfig,
       XARLP7024 HashFile, etc. Strip on every level of the chain so both regular and per-RID
       dispatches share a single cache key. -->
  <Target Name="_StrideStripPerRidGlobalsFromProjectReferences"
          BeforeTargets="_SplitProjectReferencesByFileExistence"
          Condition="'$(StridePlatform)' == 'Android' Or '$(StridePlatform)' == 'iOS'">
    <!-- Also strip RuntimeIdentifier* / SelfContained — they're set on test projects and would
         otherwise propagate to library deps as a cross-RID restore demand they don't need. -->
    <ItemGroup>
      <ProjectReference Update="@(ProjectReference)"
                        UndefineProperties="RuntimeIdentifier;RuntimeIdentifiers;SelfContained;_ComputeFilesToPublishForRuntimeIdentifiers;_OuterIntermediateAssembly;_OuterIntermediateOutputPath;_OuterCustomViewMapFile;_OuterIntermediateSatelliteAssembliesWithTargetPath;_OuterOutputPath;_AndroidNdkDirectory;AppendRuntimeIdentifierToOutputPath;DesignTimeBuild;ResolveAssemblyReferencesFindRelatedSatellites;SkipCompilerExecution" />
    </ItemGroup>
  </Target>

  <!-- ================================================================ -->
  <!-- StridePublicApi - User Documentation (.usrdoc) Support -->
  <!-- ================================================================ -->
  <PropertyGroup Condition="'$(StridePublicApi)' == 'true'">
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <AllowedOutputExtensionsInPackageBuildOutputFolder>$(AllowedOutputExtensionsInPackageBuildOutputFolder);.usrdoc</AllowedOutputExtensionsInPackageBuildOutputFolder>
    <TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);_StrideRegisterUserDocOutputs</TargetsForTfmSpecificBuildOutput>
  </PropertyGroup>
  <Target Name="_StrideRegisterUserDocOutputs">
    <ItemGroup Condition="Exists('$(OutputPath)$(AssemblyName).usrdoc')">
      <BuildOutputInPackage Include="$(OutputPath)$(AssemblyName).usrdoc"/>
    </ItemGroup>
  </Target>
  <Target Name="_StrideRegisterUserDocReferenceRelatedFileExtensions" Condition="'$(StridePublicApi)' == 'true'" BeforeTargets="ResolveAssemblyReferences">
    <PropertyGroup>
      <AllowedReferenceRelatedFileExtensions>$(AllowedReferenceRelatedFileExtensions);.usrdoc</AllowedReferenceRelatedFileExtensions>
    </PropertyGroup>
  </Target>

  <!-- ================================================================ -->
  <!-- StrideScript - Auto-enable Assembly Processor for scripts -->
  <!-- ================================================================ -->
  <PropertyGroup>
    <StrideAssemblyProcessor Condition="'$(StrideScript)' == 'true'">true</StrideAssemblyProcessor>
  </PropertyGroup>

  <!-- ================================================================ -->
  <!-- SourceLink - GitHub Source Debugging -->
  <!-- ================================================================ -->
  <ItemGroup>
    <PackageReference Include="Microsoft.SourceLink.GitHub" Condition="'$(StrideProjectType)' == 'CSharp' And '$(SkipSourceLink)' != 'true'" PrivateAssets="All" />
  </ItemGroup>

  <!-- ================================================================ -->
  <!-- StrideCompilerTargetsEnable - Conditional Build Skip -->
  <!-- ================================================================ -->
  <PropertyGroup>
    <StrideCompilerTargetsEnable Condition="'$(StrideTargetFramework)' != '$(StrideFramework)' And '$(StrideTargetFramework)' == '$(StrideFrameworkWindows)' And '$(StrideWindowsOnly)' == 'true'">false</StrideCompilerTargetsEnable>
    <!-- Skip unit tests if requested -->
    <StrideCompilerTargetsEnable Condition="'$(StrideSkipUnitTests)' == 'true' And $(StrideOutputFolder.StartsWith('Tests'))">false</StrideCompilerTargetsEnable>
    <!-- If StrideCompilerTargetsEnable is set to false, override LanguageTargets to an empty one -->
    <LanguageTargets Condition="'$(StrideCompilerTargetsEnable)' == 'false'">$(MSBuildThisFileDirectory)Stride.DisableBuild.targets</LanguageTargets>
  </PropertyGroup>

  <!-- ================================================================ -->
  <!-- Asset Packing Support (StridePackAssets) -->
  <!-- ================================================================ -->
  <!-- When StridePackAssets=true, use Stride.Core.Tasks to copy .sdpkg, assets and templates
       into the NuGet package. This is a lightweight operation that doesn't need CompilerApp. -->
  <Target Name="_StridePrepareAssetsForPack" BeforeTargets="_GetPackageFiles" Condition="'$(StridePackAssets)' == 'true'">
    <Exec Command="dotnet &quot;$(StrideRoot)sources/core/Stride.Core.Tasks/bin/$(Configuration)/$(StrideFramework)/Stride.Core.Tasks.dll&quot; pack-assets &quot;$(MSBuildProjectFile)&quot; &quot;$(IntermediateOutputPath)stride&quot;" ConsoleToMsBuild="true">
      <Output TaskParameter="ConsoleOutput" ItemName="PackAssetsLine" />
    </Exec>
    <ItemGroup>
      <PackAssetsLine Update="@(PackAssetsLine)">
        <SourcePath>$([System.String]::new('%(Identity)').Split('|')[0])</SourcePath>
        <PackagePath>$([System.String]::new('%(Identity)').Split('|')[1])</PackagePath>
      </PackAssetsLine>
      <None Include="%(PackAssetsLine.SourcePath)">
        <Pack>true</Pack>
        <PackagePath>%(PackAssetsLine.PackagePath)</PackagePath>
      </None>
    </ItemGroup>
  </Target>

  <!-- ================================================================ -->
  <!-- FastUpToDateCheck: invalidate when packed content files change -->
  <!-- ================================================================ -->
  <!-- VS's FastUpToDateCheck only watches Compile items by default. Pack-only
       content (build/buildTransitive targets, AssetPackage assets, etc.) is
       declared via None/Content with Pack="true"; if those change and
       nothing in Compile does, VS reports "up to date" and skips Build/Pack
       so the .nupkg never refreshes. Registering them as UpToDateCheckInput
       forces a rebuild whenever they're edited. -->
  <ItemGroup>
    <UpToDateCheckInput Include="@(None->WithMetadataValue('Pack', 'true'))" />
    <UpToDateCheckInput Include="@(Content->WithMetadataValue('Pack', 'true'))" />
  </ItemGroup>

  <!-- ================================================================ -->
  <!-- Auto-Pack and Deploy for NuGet Development -->
  <!-- ================================================================ -->
  <Target Name="StrideAutoPackDeploy" AfterTargets="Pack">
    <Copy Condition="'%(Extension)' == '.nupkg'" SourceFiles="@(NuGetPackOutput)" DestinationFolder="$(LocalAppData)\Stride\NugetDev"/>
    <!-- Same-version repacks: NuGet keeps the previously-extracted package in the global cache and
         skips re-extracting on consumer restore, so consumers load stale DLLs. Purge the extracted
         dir so the next consumer restore re-extracts from the freshly built .nupkg. -->
    <RemoveDir Condition="Exists('$(NuGetPackageRoot)$(PackageId.ToLowerInvariant())\$(PackageVersion)')"
               Directories="$(NuGetPackageRoot)$(PackageId.ToLowerInvariant())\$(PackageVersion)" />
  </Target>
  <!-- Per-API inner builds of cross-targeted projects (Stride.Graphics, ...) could in theory
       race on the same Stride.<X>.<ver>.nupkg, but NuGet's own IsInnerBuild gate
       (NuGet.Build.Tasks.Pack.targets, TargetFramework!='' AND TargetFrameworks!='') already
       suppresses Pack in those inner dispatches. No additional gate needed here. -->
  <PropertyGroup Condition="$(DesignTimeBuild) != 'true' And '$(StrideSkipAutoPack)' != 'true' And '$(StrideCompilerTargetsEnable)' != 'false'">
    <PackageOutputPath>$(StrideRoot)bin\packages\</PackageOutputPath>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <AllowedOutputExtensionsInPackageBuildOutputFolder>$(AllowedOutputExtensionsInPackageBuildOutputFolder);.pdb</AllowedOutputExtensionsInPackageBuildOutputFolder>
    <AllowedOutputExtensionsInPackageBuildOutputFolder>.so;.a;.bin;.dylib;$(AllowedOutputExtensionsInPackageBuildOutputFolder)</AllowedOutputExtensionsInPackageBuildOutputFolder>
  </PropertyGroup>

  <!-- ================================================================ -->
  <!-- Localization Satellite Assemblies -->
  <!-- ================================================================ -->
  <PropertyGroup>
    <StrideBuildLocalization Condition="'$(StrideBuildLocalization)' == '' And '$(StridePackageBuild)' == 'true'">true</StrideBuildLocalization>
  </PropertyGroup>
  <Target Name="StrideGenerateLocalizationSatelliteDlls"
          BeforeTargets="SatelliteDllsProjectOutputGroup"
          AfterTargets="Build"
          Returns="@(SatelliteDllsProjectOutputGroupOutput)"
          Condition="'$(StrideLocalized)' == 'true' And '$(StrideBuildLocalization)' == 'true'">
    <ItemGroup>
      <StrideTranslations Include="fr;ja;es;de;ru;it;ko"/>
      <StrideTranslations Include="zh-Hans">
        <Source>zh_HANS-CN</Source>
      </StrideTranslations>
      <_StrideTranslations Include="@(StrideTranslations)">
        <Source Condition="%(StrideTranslations.Source) == ''">%(StrideTranslations.Identity)</Source>
      </_StrideTranslations>
    </ItemGroup>
    <Message Importance="High" Text="Generating translation for %(_StrideTranslations.Identity)"/>
    <Exec Condition="Exists('$(StrideRoot)sources\localization\%(_StrideTranslations.Source)\$(TargetName).%(_StrideTranslations.Source).po')"
          Command="&quot;$(StrideRoot)deps\Gettext.Net\GNU.Gettext.Msgfmt.exe&quot; -r $(TargetName) -d &quot;$(TargetDir)\&quot; -l %(_StrideTranslations.Identity) -L &quot;$(StrideRoot)deps\Gettext.Net&quot; &quot;$(StrideRoot)sources\localization\%(_StrideTranslations.Source)\$(TargetName).%(_StrideTranslations.Source).po&quot;" />
    <ItemGroup>
      <SatelliteDllsProjectOutputGroupOutputIntermediate Include="$(OutDir)%(_StrideTranslations.Identity)\$(TargetName).Messages.resources.dll" Condition="Exists('$(OutDir)%(_StrideTranslations.Identity)\$(TargetName).Messages.resources.dll')">
        <TargetPath>%(_StrideTranslations.Identity)\$(TargetName).Messages.resources.dll</TargetPath>
        <Culture>%(_StrideTranslations.Identity)</Culture>
      </SatelliteDllsProjectOutputGroupOutputIntermediate>
    </ItemGroup>
  </Target>

  <!-- ================================================================ -->
  <!-- SharedAssemblyInfo.NuGet.cs Replacement for Package Builds -->
  <!-- ================================================================ -->
  <Target Name="StrideReplaceVersionInfo" Condition="'$(StridePackageBuild)' == 'true'" BeforeTargets="PrepareResources">
    <Error Condition="!Exists('$(StrideRoot)sources\shared\SharedAssemblyInfo.NuGet.cs')" Text="File SharedAssemblyInfo.NuGet.cs doesn't seem to have been generated. Please make sure Stride.build PackageEnvironment target has been run successfully."/>
    <ItemGroup>
      <StrideSharedAssemblyFile Include="@(Compile)" Condition="'%(Compile.FullPath)' == '$([System.IO.Path]::GetFullPath(`$(StrideRoot)sources\shared\SharedAssemblyInfo.cs`))'"/>
      <Compile Remove="@(StrideSharedAssemblyFile)" />
      <Compile Include="@(StrideSharedAssemblyFile->'$(StrideRoot)sources\shared\SharedAssemblyInfo.NuGet.cs')" />
    </ItemGroup>
  </Target>

  <!-- ================================================================ -->
  <!-- Force Pack on Inner Builds from CLI -->
  <!-- ================================================================ -->
  <Target Name="_StrideTriggerPackOnInnerBuild"
          BeforeTargets="CoreCompile"
          Condition="'$(BuildingInsideVisualStudio)' != 'true' And '$(GeneratePackageOnBuild)' == 'true'">
    <MSBuild Projects="@(_MSBuildProjectReferenceExistent)"
             Condition="'%(_MSBuildProjectReferenceExistent.SetTargetFramework)' != ''"
             BuildInParallel="$(BuildInParallel)"
             RemoveProperties="%(_MSBuildProjectReferenceExistent.GlobalPropertiesToRemove);TargetFramework;StrideGraphicsApi">
    </MSBuild>
  </Target>

  <!-- ================================================================ -->
  <!-- Local.props Bootstrap (in-source only) -->
  <!-- ================================================================ -->
  <!-- Copies Local.props.template to the repo root on first build/restore. _StrideLocalProps
       and _StrideLocalPropsTemplate are populated in Stride.Platform.props; both are empty
       for end-users consuming the SDK from NuGet (no crowdin.yml anchor), so this no-ops.
       Runs before Restore and Build to cover the dotnet build, dotnet restore, and
       no-restore flows. Imports happen during evaluation, so the just-written file is
       picked up on the next invocation, not the current one (first build uses defaults).

       Parallel project builds all fire this target concurrently; a plain <Copy> here
       races with sibling projects re-evaluating the <Import> in Stride.Platform.props
       (MSB4024: "file is being used by another process"). _StrideAtomicCopyIfMissing
       writes to a unique temp file then File.Move's it into place — atomic via
       MoveFileEx on NTFS / rename(2) on Unix. Losers of the race clean up their temp. -->
  <UsingTask TaskName="_StrideAtomicCopyIfMissing"
             TaskFactory="RoslynCodeTaskFactory"
             AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <SourceFile ParameterType="System.String" Required="true" />
      <DestinationFile ParameterType="System.String" Required="true" />
      <DidCreate ParameterType="System.Boolean" Output="true" />
    </ParameterGroup>
    <Task>
      <Code Type="Fragment" Language="cs">
        <![CDATA[
        DidCreate = false;
        if (System.IO.File.Exists(DestinationFile)) return true;
        var tmp = DestinationFile + "." + System.Guid.NewGuid().ToString("N") + ".tmp";
        try
        {
            System.IO.File.Copy(SourceFile, tmp);
            // File.Move(src, dst) throws IOException when dst already exists — the race-loser arm.
            System.IO.File.Move(tmp, DestinationFile);
            DidCreate = true;
        }
        catch (System.IO.IOException)
        {
            // Another parallel build won; clean up our temp.
            try { System.IO.File.Delete(tmp); } catch { }
        }
        return true;
        ]]>
      </Code>
    </Task>
  </UsingTask>

  <Target Name="_StrideBootstrapLocalProps"
          BeforeTargets="Restore;Build"
          Condition="'$(_StrideLocalProps)' != '' And !Exists('$(_StrideLocalProps)') And Exists('$(_StrideLocalPropsTemplate)')">
    <_StrideAtomicCopyIfMissing SourceFile="$(_StrideLocalPropsTemplate)" DestinationFile="$(_StrideLocalProps)">
      <Output TaskParameter="DidCreate" PropertyName="_StrideLocalPropsCreated" />
    </_StrideAtomicCopyIfMissing>
    <Message Importance="High" Condition="'$(_StrideLocalPropsCreated)' == 'true'"
             Text="Created $(_StrideLocalProps) from template — edit it to customize local build settings." />
  </Target>

  <!-- ================================================================ -->
  <!-- Strip unused ComInterfaceGenerator (slow, we don't use the feature) -->
  <!-- ================================================================ -->
  <Target Name="_StrideStripComInterfaceGenerator" BeforeTargets="CoreCompile">
    <ItemGroup>
      <Analyzer Remove="@(Analyzer)" Condition="'%(Filename)' == 'Microsoft.Interop.ComInterfaceGenerator'" />
    </ItemGroup>
  </Target>

  <!-- ================================================================ -->
  <!-- Configuration Validation -->
  <!-- ================================================================ -->
  <Target Name="_StrideValidateConfiguration" BeforeTargets="Build">
    <Error Condition="'$(StrideGraphicsApiDependent)' == 'true' And '$(StrideGraphicsApi)' == ''"
           Text="StrideGraphicsApi must be set when StrideGraphicsApiDependent is true. Set a default in your project or use Stride.Graphics.props." />
    <Error Condition="'$(StrideAssemblyProcessor)' == 'true' And '$(StrideAssemblyProcessorPath)' != '' And !Exists('$(StrideAssemblyProcessorPath)')"
           Text="StrideAssemblyProcessorPath '$(StrideAssemblyProcessorPath)' does not exist. Rebuild the assembly processor or check the path." />
    <Warning Condition="'$(StridePlatform)' == ''"
             Text="StridePlatform is not set. Platform-specific features may not work correctly. Check Stride.Platform.props." />
  </Target>

</Project>