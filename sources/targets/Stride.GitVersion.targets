<?xml version="1.0" encoding="utf-8"?>
<!-- StrideGitVersion task: stamps the package version from git release tags.
     Patch = next release number from releases/<major.minor>.* tags reachable from HEAD.
     Inline so there is no task assembly to build, lock, or resolve dependencies for. -->
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <_StrideGitVersionTargetsImported>true</_StrideGitVersionTargetsImported>
  </PropertyGroup>

  <UsingTask TaskName="StrideGitVersion" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <Task>
      <Code Type="Class" Language="cs">
        <![CDATA[
        using System;
        using System.Diagnostics;
        using System.IO;
        using System.Text.RegularExpressions;
        using Microsoft.Build.Framework;
        using Microsoft.Build.Utilities;

        public class StrideGitVersion : Task
        {
            [Required] public string RootDirectory { get; set; }
            [Required] public string VersionFile { get; set; }
            [Required] public string GeneratedVersionFile { get; set; }
            public string SuffixOverride { get; set; }

            [Output] public string NuGetVersion { get; set; }

            public override bool Execute()
            {
                try
                {
                    VersionFile = VersionFile.Replace('\\', '/');
                    GeneratedVersionFile = GeneratedVersionFile.Replace('\\', '/');
                    string data = File.ReadAllText(Path.Combine(RootDirectory, VersionFile));
                    string publicVersion = Regex.Match(data, "PublicVersion = \"(.*)\";").Groups[1].Value;
                    string suffix = Regex.Match(data, "NuGetVersionSuffix = \"(.*)\";").Groups[1].Value;
                    // SuffixOverride (from -p:StrideVersionSuffix) is the bare word; add the dash here.
                    if (!string.IsNullOrEmpty(SuffixOverride))
                        suffix = "-" + SuffixOverride.TrimStart('-');

                    string sha = Git("rev-parse HEAD").Substring(0, 8);

                    var v = Version.Parse(publicVersion);
                    string mm = v.Major + "." + v.Minor;
                    publicVersion = mm + "." + ResolvePatch(mm);

                    data = Regex.Replace(data, "PublicVersion = \"(.*)\";", "PublicVersion = \"" + publicVersion + "\";");
                    data = Regex.Replace(data, "NuGetVersionSuffix = \"(.*)\";", "NuGetVersionSuffix = \"" + suffix + "\";");
                    data = Regex.Replace(data, "BuildMetadata = (.*);", "BuildMetadata = \"+g" + sha + "\";");
                    File.WriteAllText(Path.Combine(RootDirectory, GeneratedVersionFile), data);

                    NuGetVersion = publicVersion + suffix;
                    return true;
                }
                catch (Exception e)
                {
                    Log.LogError("StrideGitVersion failed: " + e.Message);
                    return false;
                }
            }

            private string Git(string args)
            {
                var psi = new ProcessStartInfo("git", args)
                {
                    WorkingDirectory = RootDirectory,
                    RedirectStandardOutput = true,
                    UseShellExecute = false
                };
                using (var p = Process.Start(psi))
                {
                    string output = p.StandardOutput.ReadToEnd().Trim();
                    p.WaitForExit();
                    if (p.ExitCode != 0) throw new Exception("git " + args + " exited with " + p.ExitCode);
                    return output;
                }
            }

            // Patch from release tags, scoped to HEAD's history so branches, older builds, and fork-only
            // tags don't leak in: the exact releases/<mm>.<N> tag on HEAD (idempotent re-release, no +1),
            // else the highest one reachable from HEAD + 1, else 0 with a dev-oriented warning.
            private int ResolvePatch(string mm)
            {
                int patch;
                if (TryMaxPatch(Git("tag --points-at HEAD --list releases/" + mm + ".*"), mm, out patch))
                    return patch;
                if (TryMaxPatch(Git("tag --list releases/" + mm + ".* --merged HEAD"), mm, out patch))
                    return patch + 1;
                bool shallow = Git("rev-parse --is-shallow-repository") == "true";
                Log.LogWarning("No releases/" + mm + ".* tags reachable from HEAD - using " + mm + ".0. " +
                    (shallow ? "This looks like a shallow clone; run `git fetch --unshallow` to get the release tags."
                             : "Run `git fetch --tags` to fetch the release tags."));
                return 0;
            }

            // Highest patch N among "releases/<mm>.<N>" lines (stable releases only; suffixed prerelease
            // tags are ignored, so the suffix is the pre-release of the same N). Returns false if none.
            private bool TryMaxPatch(string tagList, string mm, out int best)
            {
                best = -1;
                var rx = new Regex("^releases/" + Regex.Escape(mm) + "\\.(\\d+)$");
                foreach (var tag in tagList.Split('\n'))
                {
                    var m = rx.Match(tag.Trim());
                    if (m.Success)
                    {
                        int p = int.Parse(m.Groups[1].Value);
                        if (p > best) best = p;
                    }
                }
                return best >= 0;
            }
        }
        ]]>
      </Code>
    </Task>
  </UsingTask>

</Project>
