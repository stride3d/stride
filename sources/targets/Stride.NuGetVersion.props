<!-- Engine NuGet version derivation, shared by Stride.PackageInfo.targets (Stride SDK) and
     Stride.Templates.Common.targets (which uses the vanilla Microsoft.NET.Sdk, outside the Stride SDK chain).
     Reads the version fields from SharedAssemblyInfo[.Generated].cs into StrideNuGetVersion (+ its parts). Pure
     property derivation (no targets / no SDK dependency), so it is safe to import from any project. The -devN
     worktree suffix is appended separately by the producer (StrideAppendWorktreeVersion in Stride.PackageInfo). -->
<Project>
  <PropertyGroup>
    <!-- Package builds read the generated overlay (version + suffix + git metadata); other builds read the
         committed source. -->
    <_StrideSharedAssemblyInfoFile Condition="'$(StridePackageBuild)' == 'true'">$(StrideRoot)sources/shared/SharedAssemblyInfo.Generated.cs</_StrideSharedAssemblyInfoFile>
    <_StrideSharedAssemblyInfoFile Condition="'$(StridePackageBuild)' != 'true'">$(StrideRoot)sources/shared/SharedAssemblyInfo.cs</_StrideSharedAssemblyInfoFile>
    <_StrideSharedAssemblyInfoLines>$([System.IO.File]::ReadAllText('$(_StrideSharedAssemblyInfoFile)'))</_StrideSharedAssemblyInfoLines>
    <!-- Package version = MajorMinor.Patch. PublicVersion is the consumer-facing const and is not read here. -->
    <_StridePackageMajorMinor>$([System.Text.RegularExpressions.Regex]::Match($(_StrideSharedAssemblyInfoLines), `.*MajorMinor = \"(.*)\";.*`).Groups[1].Value)</_StridePackageMajorMinor>
    <_StridePackagePatch>$([System.Text.RegularExpressions.Regex]::Match($(_StrideSharedAssemblyInfoLines), `.*[^a-zA-Z]Patch = \"(.*)\";.*`).Groups[1].Value)</_StridePackagePatch>
    <_StridePackagePublicVersion>$(_StridePackageMajorMinor).$(_StridePackagePatch)</_StridePackagePublicVersion>
    <StrideNuGetVersionSuffix>$([System.Text.RegularExpressions.Regex]::Match($(_StrideSharedAssemblyInfoLines), `.*NuGetVersionSuffix = \"(.*)\";.*`).Groups[1].Value)</StrideNuGetVersionSuffix>
    <StrideBuildMetadata>$([System.Text.RegularExpressions.Regex]::Match($(_StrideSharedAssemblyInfoLines), `.*BuildMetadata = \"(.*)\";.*`).Groups[1].Value)</StrideBuildMetadata>
    <StrideNuGetVersion>$(_StridePackagePublicVersion)$(StrideNuGetVersionSuffix)$(StrideBuildMetadata)</StrideNuGetVersion>
  </PropertyGroup>
</Project>
