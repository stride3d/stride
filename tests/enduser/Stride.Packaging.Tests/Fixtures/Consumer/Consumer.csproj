<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <RootNamespace>Consumer</RootNamespace>
    <Nullable>enable</Nullable>
    <!-- Real-game shape: platform-head executable with no sdpkg of its own; assets flow in from
         the referenced .Game project's package. -->
    <StrideContainsAssetTypes>false</StrideContainsAssetTypes>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="Consumer.Game\Consumer.Game.csproj" />
  </ItemGroup>
</Project>
