// Image comparison thresholds for Stride.Graphics.Tests
// Built-in default (no file needed): any pixel with diff >= 3 fails.
// Only add entries here for images that need relaxed thresholds.
//
// Format:
//   image    - image filename (required, or omit for suite-wide default); supports '*' and '?' wildcards
//   platform - "Windows", "Linux", "macOS" (optional, omit = any)
//   api      - "Vulkan", "Direct3D11", "Direct3D12" (optional, omit = any)
//   device   - "SwiftShader", "WARP", GPU name (optional, omit = any)
//   allow    - max allowed pixel counts per diff range (e.g. "1-2": 500, "16+": 2)
[
  {
    // Knight model edges flicker a few pixels between runs due to sub-pixel
    // rasterization plus CPU float divergence in skinning; observed across
    // software renderers (Lavapipe/WARP) and on Apple Silicon. Tolerated on
    // every platform and every frame of the animation.
    "image": "AnimatedModelTests*.png",
    "allow": { "3-5": 10, "6-15": 6, "16+": 3 }
  },
  {
    // One pixel on the sprite's anti-aliased edge varies by diff 3 between runs.
    "image": "SpriteRenderer3DTests*.png",
    "allow": { "3-5": 2 }
  },
  // Some slight pixel edges/aliasing differences (probably due to CPU floating point divergence)
  // Allow them: it's quite minor if only so few pixels for wireframe
  {
    "image": "TesselationTest.png",
    "allow": { "3+": 10 }
  },
  {
    "image": "TesselationTest.f1.png",
    "allow": { "3+": 10 }
  },
  {
    "image": "TesselationTest.f2.png",
    "allow": { "3+": 10 }
  },
  {
    "image": "TesselationTest.f3.png",
    "allow": { "3+": 10 }
  },
  {
    "image": "TesselationTest.f4.png",
    "allow": { "3+": 15 }
  },
  {
    "image": "TesselationTest.f5.png",
    "allow": { "3+": 50 }
  }
]
